<div class="hdt-payments-wrap" {{ block.shopify_attributes }}>

  {%- assign arr = block.settings.svg | remove:' ' | split:',' -%}


  <div
    class="hdt-pr hdt-row-flex"
    style="
      --height-img:{{ block.settings.height }}px;
      gap:10px;
    "
  >


    {% for img in arr %}


      {% if img contains 'cust4__' %}


        {% assign getIMG = img | remove_first:'cust4__' %}
        {% assign image = images[getIMG] %}


        {% if image != blank %}

          <img

          loading="lazy"

          class="lazyloadhdt"

          src="{{ image | image_url: width:100 }}"

          width="{{ image.width }}"

          height="{{ image.height }}"

          alt="{{ image.alt | escape }}"

          >

        {% endif %}



      {% else %}


        <img

        loading="lazy"

        class="lazyloadhdt"

        src="https://raw.githubusercontent.com/activemerchant/payment_icons/refs/heads/master/app/assets/images/payment_icons/{{ img }}.svg"

        alt="{{ img | replace:'_',' ' }}"

        >

      {% endif %}



    {% endfor %}


  </div>

</div>



<style>

.hdt-payments-wrap img{

height:var(--height-img);

width:auto;

display:block;

}

</style>



{% schema %}
{
"name":"Payment icons",

"class":"hdt-payment-icons",

"settings":[

{
"type":"textarea",
"id":"svg",
"label":"Payment icons",
"default":"amazon,american_express,apple_pay,bitcoin",

"info":"amazon,american_express,apple_pay,bitcoin,dankort,diners_club,discover,dogecoin,dwolla,forbrugsforeningen,interac,google_pay,jcb,klarna,klarna-pay-later,litecoin,maestro,master,paypal,shopify_pay,sofort,visa"

},


{
"type":"number",
"id":"height",
"label":"Icon height",
"default":30
}

],


"presets":[

{
"name":"Payment icons"
}

]

}
{% endschema %}