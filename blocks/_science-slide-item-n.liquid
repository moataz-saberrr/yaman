<!-- blocks/_science-slide-item-n.liquid — YAMAN "Science Behind the Glow" card (duplicated from _slide-item.liquid) -->
{%- liquid
  assign img = block.settings.image
  assign img_mb = block.settings.image_mb | default: block.settings.image
-%}
<div id="block_id-{{ block.id }}" class="hdt-slider__slide hdt-yaman-science__slide" {{ block.shopify_attributes }}>
  <div class="hdt-yaman-science__card">
    <div class="hdt-yaman-science__media">
      {%- if img != blank -%}
        <picture class="hdt-yaman-science__picture">
          {%- if block.settings.image_mb != blank and block.settings.image_mb != block.settings.image -%}
            <source media="(max-width: 767px)" srcset="{{ img_mb | image_url: width: 1000 }}">
          {%- endif -%}
          {{ img | image_url: width: img.width | image_tag: loading: 'lazy', class: 'hdt-yaman-science__img', sizes: '(min-width: 768px) 70vw, 90vw', widths: '400,600,800,1000,1200,1400,1600,1800,2000' }}
        </picture>
      {%- else -%}
        <div class="hdt-yaman-science__placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <span class="hdt-yaman-science__overlay" aria-hidden="true"></span>

    {%- if block.settings.url != blank -%}
      <a class="hdt-yaman-science__link" href="{{ block.settings.url }}" target="{% if block.settings.banner_target %}_blank{% else %}_self{% endif %}" aria-label="{{ block.settings.title | escape }}"></a>
    {%- endif -%}

    <div class="hdt-yaman-science__content">
      {%- if block.settings.title != blank -%}
        <h3 class="hdt-yaman-science__title">{{ block.settings.title }}</h3>
      {%- endif -%}
      {%- if block.settings.description != blank -%}
        <p class="hdt-yaman-science__description">{{ block.settings.description }}</p>
      {%- endif -%}

      {%- if block.settings.tag_1 != blank or block.settings.tag_2 != blank or block.settings.tag_3 != blank -%}
        <ul class="hdt-yaman-science__tags">
          {%- if block.settings.tag_1 != blank -%}<li class="hdt-yaman-science__tag">{{ block.settings.tag_1 }}</li>{%- endif -%}
          {%- if block.settings.tag_2 != blank -%}<li class="hdt-yaman-science__tag">{{ block.settings.tag_2 }}</li>{%- endif -%}
          {%- if block.settings.tag_3 != blank -%}<li class="hdt-yaman-science__tag">{{ block.settings.tag_3 }}</li>{%- endif -%}
        </ul>
      {%- endif -%}

      {%- if block.settings.used_in != blank -%}
        <p class="hdt-yaman-science__used">{{ block.settings.used_in }}</p>
      {%- endif -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Science slide",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mb",
      "label": "Image (mobile)",
      "info": "Optional. Falls back to the desktop image."
    },
    {
      "type": "url",
      "id": "url",
      "label": "Slide link"
    },
    {
      "type": "checkbox",
      "id": "banner_target",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Technology title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Describe how this technology works and the visible results it delivers."
    },
    {
      "type": "header",
      "content": "Tags"
    },
    {
      "type": "text",
      "id": "tag_1",
      "label": "Tag 1"
    },
    {
      "type": "text",
      "id": "tag_2",
      "label": "Tag 2"
    },
    {
      "type": "text",
      "id": "tag_3",
      "label": "Tag 3"
    },
    {
      "type": "header",
      "content": "Used in"
    },
    {
      "type": "text",
      "id": "used_in",
      "label": "Used in text",
      "default": "Used in: Product name"
    }
  ],
  "presets": [
    {
      "name": "Science slide"
    }
  ]
}
{% endschema %}
