<div class="hdt-product-info__item hdt-product__simple-featured" {{ block.shopify_attributes }}>
  {%- assign f_product = block.settings.product -%}
  {%- if f_product != blank -%}
    {%- assign f_variant = f_product.selected_or_first_available_variant -%}
    
    <div class="hdt-simple-featured-card">
      <div class="hdt-simple-featured-content">
        <h4 class="hdt-simple-featured-title">
          {{ block.settings.heading | default: f_product.title }}
        </h4>
        <div class="hdt-simple-featured-price">
          {{ f_variant.price | money_without_trailing_zeros }}
        </div>
        <a href="{{ f_product.url }}" class="hdt-simple-featured-btn">
          {{ block.settings.button_text | default: 'SHOP NOW' }}
        </a>
      </div>
      
      <div class="hdt-simple-featured-image-wrap">
        <a href="{{ f_product.url }}">
          {%- assign f_image = f_variant.image | default: f_product.featured_image -%}
          {%- if f_image != blank -%}
            {{ f_image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'hdt-simple-featured-img' }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'hdt-placeholder-svg hdt-simple-featured-img' }}
          {%- endif -%}
        </a>
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  .hdt-product__simple-featured {
    width: 100%;
  }
  .hdt-simple-featured-card {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .hdt-simple-featured-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hdt-simple-featured-title {
    font-size: 48px;
    font-weight: 700;
    color: #070707;
    margin-bottom: 12px;
    text-transform: uppercase;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }
  .hdt-simple-featured-price {
    font-size: 43px;
    font-weight: 700;
    color: #1d2847;
    margin-bottom: 24px;
  }
  .hdt-simple-featured-btn {
    background-color: #1d2847;
    color: #ffffff;
    font-size: 22px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    width: 80%;
    height: 69px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    max-width: 100%;
  }
  .hdt-simple-featured-btn:hover {
    opacity: 0.85;
  }
  .hdt-simple-featured-image-wrap {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: {{ block.settings.bg_color | default: '#ffffff' }};
  }
  .hdt-simple-featured-image-wrap a {
    display: block;
    width: 100%;
    text-align: center;
    max-width: fit-content;
        border: 1px solid {{ block.settings.border_color | default: '#efeae0' }};
    border-radius: 12px;
  }
  .hdt-simple-featured-img {
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }

  @media (max-width: 1150px) {
    .hdt-simple-featured-title {
      font-size: 38px;
    }
    .hdt-simple-featured-price{
      font-size: 38px;
    }
    .hdt-simple-featured-btn{
      font-size: 20px;
      height: 56px;
    }
  }

  @media (max-width: 767px) {
    .hdt-simple-featured-card {
      flex-direction: column-reverse;
      text-align: center;
      gap: 20px;
    }
    .hdt-simple-featured-content {
      align-items: center;
      width: 100%;
    }
    .hdt-simple-featured-title {
      font-size: 25px;
      margin-bottom: 8px;
    }
    .hdt-simple-featured-price {
      font-size: 25px;
      margin-bottom: 16px;
    }
    .hdt-simple-featured-btn {
      width: 80%;
      height: 56px
      font-size: 18px;
    }

    .hdt-simple-featured-image-wrap {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Simple Featured Product",
  "tag": null,
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured Product"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Override",
      "info": "Leave blank to use the product's title."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP THE MASK"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#efeae0"
    }
  ],
  "presets": [
    {
      "name": "Simple Featured Product"
    }
  ]
}
{% endschema %}
