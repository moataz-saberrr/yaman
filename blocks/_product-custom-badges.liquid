<div class="hdt-product-info__item hdt-product__custom-badges" {{ block.shopify_attributes }}>
  <div class="hdt-custom-badges-wrap">
    {%- for i in (1..4) -%}
      {%- capture text_key -%}text_{{ i }}{%- endcapture -%}
      {%- capture icon_svg_key -%}icon_svg_{{ i }}{%- endcapture -%}
      {%- capture icon_image_key -%}icon_image_{{ i }}{%- endcapture -%}
      {%- capture bg_color_key -%}bg_color_{{ i }}{%- endcapture -%}

      {%- assign text = block.settings[text_key] -%}
      {%- assign icon_svg = block.settings[icon_svg_key] -%}
      {%- assign icon_image = block.settings[icon_image_key] -%}
      {%- assign bg_color = block.settings[bg_color_key] -%}

      {%- if text != blank or icon_svg != blank or icon_image != blank -%}
        <div class="hdt-custom-badge-item" style="background-color: {{ bg_color }};">
          {%- if icon_svg != blank -%}
            <span class="hdt-badge-icon">{{ icon_svg }}</span>
          {%- elsif icon_image != blank -%}
            <img src="{{ icon_image | image_url: width: 40 }}" alt="{{ text | escape }}" width="{{ icon_image.width }}" height="{{ icon_image.height }}" class="hdt-badge-icon-img" loading="lazy">
          {%- endif -%}
          
          {%- if text != blank -%}
            <span class="hdt-badge-text">{{ text }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  .hdt-product__custom-badges {
    margin: 20px 0;
  }
  .hdt-custom-badges-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .hdt-custom-badge-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 10px;
    border-radius: 8px;
    /* flex: 1 1 auto; */
    /* min-width: fit-content; */
  }
  .hdt-badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #64748b; /* Blueish grey from screenshot */
  }
  .hdt-badge-icon svg {
    width: 16px;
    height: 16px;
    display: block;
    fill: currentColor;
    stroke: currentColor;
  }
  .hdt-badge-icon-img {
    width: 16px;
    height: auto;
    object-fit: contain;
    display: block;
  }
  .hdt-badge-text {
    color: #64748b;
    white-space: nowrap;
    font-family: DIN Next LT W23;
    font-weight: 400;
    font-size: 13px;
    line-height: 19px;
    text-align: center;
  }

  @media (max-width: 767px) {
    .hdt-custom-badges-wrap {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .hdt-custom-badge-item {
      padding: 12px 10px;
      flex-direction: row-reverse;
      text-align: center;
    }
    .hdt-badge-text {
      text-transform: none;
      font-size: 13px;
      white-space: normal;
      font-weight: 500;
    }
  }
</style>

