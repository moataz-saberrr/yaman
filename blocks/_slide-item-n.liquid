{%- comment -%}
  YAMAN Hero slide block — used ONLY by sections/slideshow-n.liquid.
  Custom duplicate of _slide-item.liquid; the original shared block is left untouched.
  Layout:
    - Desktop/tablet: image fills the slide, content overlays on top (left aligned) + dark gradient overlay.
    - Mobile: black content panel stacked ABOVE the image (one slide = panel + image).
  All styling lives in assets/custom_yaman.css, scoped under .hdt-slideshow-n
{%- endcomment -%}
{%- liquid
  assign fetch = 'low'
  if section.index <= 3
    assign block_index = section.blocks | find_index: 'id', block.id
    if block_index == 0
      assign fetch = 'high'
    endif
  endif
  assign image_mb = block.settings.image_mb | default: block.settings.image
  assign heading_dk = block.settings.heading
  assign has_mb_heading = false
  if block.settings.heading_mb != blank and block.settings.heading_mb != heading_dk
    assign has_mb_heading = true
  endif
-%}
<div
  id="block_id-{{ block.id }}"
  class="hdt-slider__slide hdt-slideshow_item hdt-yaman-hero__slide hdt-oh{% if block.settings.accent_last_line %} is-accent{% endif %}"
  {{ block.shopify_attributes }}
  style="--yaman-accent: {{ block.settings.accent_color }}; --yaman-panel: {{ block.settings.panel_color }}; --yh-ratio-md: {{ block.settings.image.aspect_ratio | default: 2.0 }}; --yh-ratio: {{ image_mb.aspect_ratio | default: block.settings.image.aspect_ratio | default: 1.5 }};"
>
  <div class="hdt-yaman-hero__inner">
    <div class="hdt-yaman-hero__media">
      {%- if block.settings.image != blank -%}
        <picture class="hdt-yaman-hero__picture">
          {%- if image_mb != blank and image_mb != block.settings.image -%}
            <source
              media="(max-width: 767px)"
              srcset="{{ image_mb | image_url: width: 600 }} 600w, {{ image_mb | image_url: width: 900 }} 900w, {{ image_mb | image_url: width: 1200 }} 1200w, {{ image_mb | image_url: width: 1500 }} 1500w"
              sizes="100vw"
            >
          {%- endif -%}
          {{
            block.settings.image
            | image_url: width: block.settings.image.width
            | image_tag:
              loading: 'eager',
              fetchpriority: fetch,
              class: 'hdt-yaman-hero__img',
              sizes: '100vw',
              widths: '600,800,1000,1200,1400,1600,1800,2000,2400,2800,3200',
              alt: block.settings.image.alt
          }}
        </picture>
      {%- else -%}
        <div class="hdt-yaman-hero__img hdt-yaman-hero__placeholder">
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
      <span class="hdt-yaman-hero__overlay" aria-hidden="true"></span>
    </div>

    <div class="hdt-yaman-hero__content">
      <div class="hdt-yaman-hero__content-inner">
        {%- if heading_dk != blank -%}
          <h2 class="hdt-yaman-hero__heading{% if has_mb_heading %} hdt-yaman-hero__heading--has-mb{% endif %}">
            <span class="hdt-yaman-hero__heading-group hdt-yaman-hero__heading-group--dk">
              {%- assign dk_lines = heading_dk | escape | newline_to_br | split: '<br />' -%}
              {%- for line in dk_lines -%}
                {%- assign l = line | strip -%}
                {%- if l != blank %}<span class="hdt-yaman-hero__line">{{ l }}</span>{% endif -%}
              {%- endfor -%}
            </span>
            {%- if has_mb_heading -%}
              <span class="hdt-yaman-hero__heading-group hdt-yaman-hero__heading-group--mb">
                {%- assign mb_lines = block.settings.heading_mb | escape | newline_to_br | split: '<br />' -%}
                {%- for line in mb_lines -%}
                  {%- assign l = line | strip -%}
                  {%- if l != blank %}<span class="hdt-yaman-hero__line">{{ l }}</span>{% endif -%}
                {%- endfor -%}
              </span>
            {%- endif -%}
          </h2>
        {%- endif -%}

        {%- if block.settings.subheading != blank -%}
          <div class="hdt-yaman-hero__text">{{ block.settings.subheading }}</div>
        {%- endif -%}

        {%- if block.settings.button_label != blank -%}
          <a
            class="hdt-yaman-hero__button"
            {% if block.settings.button_link != blank %}href="{{ block.settings.button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
            {% if block.settings.button_target %}target="_blank" rel="noopener"{% endif %}
          >{{ block.settings.button_label }}</a>
        {%- endif -%}

        {%- if block.settings.meta_text != blank -%}
          <ul class="hdt-yaman-hero__meta" role="list">
            {%- assign meta_items = block.settings.meta_text | split: '|' -%}
            {%- for item in meta_items -%}
              {%- assign m = item | strip -%}
              {%- if m != blank %}<li class="hdt-yaman-hero__meta-item">{{ m }}</li>{% endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "YAMAN Hero slide",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (desktop)",
      "info": "Recommended wide image, e.g. 2800 x 900px. Used as the full-bleed background on desktop."
    },
    {
      "type": "image_picker",
      "id": "image_mb",
      "label": "Image (mobile)",
      "info": "Optional. Shown below the black content panel on mobile. Falls back to the desktop image if empty."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "One line per row. Each row renders as a separate heading line.",
      "default": "LIFT.\nSCULPT.\nREDEFINE."
    },
    {
      "type": "textarea",
      "id": "heading_mb",
      "label": "Heading (mobile override)",
      "info": "Optional. Leave empty to reuse the desktop heading on mobile."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>46 years of R&D. 345+ patents. Clinical-grade technology designed for you.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP MEDI LIFT PLUS — 1,700 SAR"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_target",
      "label": "Open button link in a new tab",
      "default": false
    },
    {
      "type": "text",
      "id": "meta_text",
      "label": "Trust / meta line",
      "info": "Separate items with a vertical bar |",
      "default": "345+ PATENTS | ISO 13485 CERTIFIED | 10M+ UNITS SOLD"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "accent_last_line",
      "label": "Accent the last heading line",
      "info": "Colours the final heading line with the accent colour (matches the mobile comp).",
      "default": false
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour (button + accent line)",
      "default": "#f5ebdd"
    },
    {
      "type": "color",
      "id": "panel_color",
      "label": "Mobile panel / overlay colour",
      "default": "#070707"
    }
  ]
}
{% endschema %}
