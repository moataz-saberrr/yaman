{%-liquid
  assign target = product
  assign product = section.settings.product | default: target

  assign un_no_pick = true
  if settings.pick_mode == 'no' and product.variants.size > 1
    assign selected_variant = product.selected_variant
    unless selected_variant
      assign un_no_pick = false
    endunless
  elsif settings.pick_mode == 'first' and settings.hide_sold_out == false
    assign selected_variant = product.selected_variant | default: product.variants.first
  else
    assign selected_variant = product.selected_or_first_available_variant
  endif

  assign variant_price = selected_variant.price
  assign installment_price = variant_price | divided_by: 4
  assign currency_code = cart.currency.iso_code
-%}
<div class="hdt-product-info__item hdt-product__tabby-installment" {{ block.shopify_attributes }} >
  <div class="hdt-tabby-installment-text" data-tabby-installment>
    {%- if block.settings.text_before_price != blank -%}
      <span>{{ block.settings.text_before_price }}</span>
    {%- endif -%}
    
    <span class="hdt-tabby-price-wrap">
      <span data-tabby-currency>{{ currency_code }}</span>
      <span data-tabby-price>{{ installment_price | money_without_currency | replace: '.00', '' | strip_html }}</span>
    </span>

    {%- if block.settings.tamara_image != blank -%}
      <img src="{{ block.settings.tamara_image | image_url: width: 150 }}" alt="Tamara" height="{{ block.settings.tamara_image.height }}" width="{{ block.settings.tamara_image.width }}" class="hdt-payment-logo" loading="lazy">
    {%- endif -%}

    {%- if block.settings.text_between_images != blank -%}
      <span>{{ block.settings.text_between_images }}</span>
    {%- endif -%}

    {%- if block.settings.tabby_image != blank -%}
      <img src="{{ block.settings.tabby_image | image_url: width: 150 }}" alt="Tabby" height="{{ block.settings.tabby_image.height }}" width="{{ block.settings.tabby_image.width }}" class="hdt-payment-logo" loading="lazy">
    {%- endif -%}
  </div>
  {%- if product.variants.size > 1 -%}
    {%- comment -%} per-variant installment values for the JS to swap on variant change {%- endcomment -%}
    <script type="application/json" data-tabby-installments>
      {
        {%- for v in product.variants -%}
          "{{ v.id }}": {{ v.price | divided_by: 4 | money_without_currency | replace: '.00', '' | strip_html | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      }
    </script>
  {%- endif -%}
</div>

<style>
  .hdt-product__tabby-installment {
        background-color: #F8F7F0;
    border-bottom: 1px solid #E0E0E0;
    padding-top: 14px;
    padding-inline: 24px;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    margin-bottom: 0 !important;
    @media (max-width: 1150px) {
      padding-top: 12px;
      padding-inline: 18px;
      
    }
  }
  .hdt-tabby-installment-text {
    font-size: 14px;
    margin: 0;
    line-height: 27px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-block: 8px
  }
  .hdt-tabby-price-wrap {
    font-weight: 700;
  }
  .hdt-payment-logo {
    height: 24px;
    width: auto;
    object-fit: contain;
    display: inline-block;
  }
</style>
{%- if product.variants.size > 1 -%}
  <script src="{{ 'tabby-installment.js' | asset_url }}" defer></script>
{%- endif -%}
{% schema %}
{
  "name": "Tabby Installment",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text_before_price",
      "label": "Text before price",
      "default": "Split it into 4 installments of"
    },
    {
      "type": "image_picker",
      "id": "tamara_image",
      "label": "Tamara Logo"
    },
    {
      "type": "text",
      "id": "text_between_images",
      "label": "Text between logos",
      "default": "or"
    },
    {
      "type": "image_picker",
      "id": "tabby_image",
      "label": "Tabby Logo"
    }
  ],
  "presets": [{ "name": "Tabby Installment" }]
}
{% endschema %}
