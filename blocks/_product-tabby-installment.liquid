{%-liquid
  assign target = product
  assign product = section.settings.product | default: target

  assign un_no_pick = true
  if settings.pick_mode == 'no' and product.variants.size > 1
    assign selected_variant = product.selected_variant
    unless selected_variant
      assign un_no_pick = false
    endunless
  elsif settings.pick_mode == 'first' and settings.hide_sold_out == false
    assign selected_variant = product.selected_variant | default: product.variants.first
  else
    assign selected_variant = product.selected_or_first_available_variant
  endif

  assign variant_price = selected_variant.price
  assign installment_price = variant_price | divided_by: 4
  assign currency_code = cart.currency.iso_code
-%}
<div class="hdt-product-info__item hdt-product__tabby-installment" {{ block.shopify_attributes }} >
  <p class="hdt-tabby-installment-text" data-tabby-installment>
    <span>or </span>
    <span data-tabby-currency>{{ currency_code }}</span>
    <span>&nbsp;</span>
    <span data-tabby-price>{{ installment_price | money_without_currency | strip_html }}</span>
    <span>/month × 4 with </span>
    <span class="hdt-tabby-brand">Tabby</span>
  </p>
  {%- if product.variants.size > 1 -%}
    {%- comment -%} per-variant installment values for the JS to swap on variant change {%- endcomment -%}
    <script type="application/json" data-tabby-installments>
      {
        {%- for v in product.variants -%}
          "{{ v.id }}": {{ v.price | divided_by: 4 | money_without_currency | strip_html | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      }
    </script>
  {%- endif -%}
</div>

<style>
  .hdt-product__tabby-installment {
    margin: 0;
  }
  .hdt-tabby-installment-text {
    font-size: 14px;
    color: #9b8e7e;
    margin: 0;
    line-height: 27px;
  }
</style>
{%- if product.variants.size > 1 -%}
  <script src="{{ 'tabby-installment.js' | asset_url }}" defer></script>
{%- endif -%}
{% schema %}
{
  "name": "Tabby Installment",
  "tag": null,
  "settings": [],
  "presets": [{ "name": "Tabby Installment" }]
}
{% endschema %}
