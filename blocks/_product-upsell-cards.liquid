<div class="hdt-product-info__item hdt-product__upsell-cards" {{ block.shopify_attributes }}>
  {%- assign product_1 = block.settings.product_1 -%}
  {%- assign product_2 = block.settings.product_2 -%}
  
  {%- if product_1 != blank or product_2 != blank -%}
    <div class="hdt-upsell-cards-wrapper">
      {%- if block.settings.heading != blank -%}
        <h4 class="hdt-upsell-cards-heading">{{ block.settings.heading }}</h4>
      {%- endif -%}
      
      <div class="hdt-upsell-cards-grid">
        {%- if product_1 != blank -%}
          {%- assign variant_1 = product_1.selected_or_first_available_variant -%}
          <a href="{{ product_1.url }}" class="hdt-upsell-card-box">
            <div class="hdt-upsell-card-info">
              <span class="hdt-upsell-card-title">{{ product_1.title }}</span>
              <div class="hdt-upsell-card-price-wrap">
                <span class="hdt-upsell-card-price">{{ variant_1.price | money_without_trailing_zeros }}</span>
                {%- if variant_1.compare_at_price > variant_1.price -%}
                  <span class="hdt-upsell-card-compare">{{ variant_1.compare_at_price | money_without_trailing_zeros }}</span>
                {%- endif -%}
              </div>
            </div>
            <div class="hdt-upsell-card-img-wrap">
              {%- assign v_img_1 = variant_1.image | default: product_1.featured_image -%}
              {%- if v_img_1 != blank -%}
                {{ v_img_1 | image_url: width: 150 | image_tag: loading: 'lazy', class: 'hdt-upsell-card-img' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'hdt-placeholder-svg hdt-upsell-card-img' }}
              {%- endif -%}
            </div>
          </a>
        {%- endif -%}

        {%- if product_2 != blank -%}
          {%- assign variant_2 = product_2.selected_or_first_available_variant -%}
          <a href="{{ product_2.url }}" class="hdt-upsell-card-box">
            <div class="hdt-upsell-card-info">
              <span class="hdt-upsell-card-title">{{ product_2.title }}</span>
              <div class="hdt-upsell-card-price-wrap">
                <span class="hdt-upsell-card-price">{{ variant_2.price | money_without_trailing_zeros }}</span>
                {%- if variant_2.compare_at_price > variant_2.price -%}
                  <span class="hdt-upsell-card-compare">{{ variant_2.compare_at_price | money_without_trailing_zeros }}</span>
                {%- endif -%}
              </div>
            </div>
            <div class="hdt-upsell-card-img-wrap">
              {%- assign v_img_2 = variant_2.image | default: product_2.featured_image -%}
              {%- if v_img_2 != blank -%}
                {{ v_img_2 | image_url: width: 150 | image_tag: loading: 'lazy', class: 'hdt-upsell-card-img' }}
              {%- else -%}
                {{ 'product-2' | placeholder_svg_tag: 'hdt-placeholder-svg hdt-upsell-card-img' }}
              {%- endif -%}
            </div>
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  .hdt-product__upsell-cards {
    margin-top: 24px;
    margin-bottom: 24px;
  }
  .hdt-upsell-cards-heading {
    font-size: 18px;
    font-weight: 600;
    color: #4a5568;
    margin-bottom: 15px;
    letter-spacing: 0;
  }
  .hdt-upsell-cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .hdt-upsell-card-box {
    background-color: #f9f8f2;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    text-decoration: none;
    border: 1px solid #efeae0;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .hdt-upsell-card-box:hover {
    transform: translateY(-2px);
    border-color: #d4b87a;
  }
  .hdt-upsell-card-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .hdt-upsell-card-title {
    font-size: 15px;
    color: #374151;
    font-weight: 500;
    line-height: 1.3;
  }
  .hdt-upsell-card-price-wrap {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hdt-upsell-card-price {
    font-size: 18px;
    font-weight: 700;
    color: #737373;
  }
  .hdt-upsell-card-compare {
    font-size: 13px;
    color: #a3a3a3;
    text-decoration: line-through;
  }
  .hdt-upsell-card-img-wrap {
    width: 76px;
    height: 76px;
    background-color: #ffffff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .hdt-upsell-card-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  
  @media (max-width: 767px) {
    .hdt-upsell-cards-heading {
      font-size: 16px;
    }
    .hdt-upsell-cards-grid {
      gap: 10px;
    }
    .hdt-upsell-card-box {
      padding: 12px 10px;
      gap: 8px;
    }
    .hdt-upsell-card-title {
      font-size: 12px;
      line-height: 1.2;
    }
    .hdt-upsell-card-price {
      font-size: 14px;
    }
    .hdt-upsell-card-compare {
      font-size: 11px;
    }
    .hdt-upsell-card-img-wrap {
      width: 54px;
      height: 54px;
      border-radius: 10px;
    }
  }
  @media (max-width: 380px) {
    .hdt-upsell-card-img-wrap {
      width: 44px;
      height: 44px;
    }
  }
</style>

{% schema %}
{
  "name": "Product Upsell Cards",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recommended to use the serum with:"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    }
  ],
  "presets": [
    {
      "name": "Product Upsell Cards"
    }
  ]
}
{% endschema %}
