<!-- section/slideshow-n.liquid — YAMAN Hero Slideshow (custom; do NOT confuse with the original Kalles slideshow.liquid) -->
{{ 'slideshow.css' | asset_url | stylesheet_tag: media: 'all' }}
{%- style -%}
  .hdt-section-spacing-{{ section.id }} {
    --yaman-hero-h: {{ section.settings.hero_min_height }}px;
    --yaman-hero-img-h-mb: {{ section.settings.hero_image_height_mb }}px;
    --yaman-hero-ov: {{ section.settings.overlay_opacity | divided_by: 100.00 }};
  }
  {%- render 'spacing-vars', box: section -%}
{%- endstyle -%}

<div class="hdt-s-inner hdt-section-spacing hdt-section-spacing-{{ section.id }} hdt-s-gradient" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};" {%- endif %} {%- unless section.index == 1 %} hdt-reveal="fade-in"{%- endunless -%}>
  <hdt-slideshow {% if section.settings.is_fade %}isfade {% endif %}id="Slider-{{ section.id }}" autoheight class="hdt-slider hdt-relative hdt-container{% if section.settings.full_width %}-full{% endif %} hdt-slideshow hdt-slides-1 hdt-yaman-hero" config='{"loop": {{ section.settings.loop }}, "navUI": {{ section.settings.navUI }}, "dotUI": {{ section.settings.dotUI }}, "autoPlay": {{ section.settings.autoplay | times: 1000 }}, "pauseOnHover": {{ section.settings.pauseOnHover }}, "autoHeight": true, "slidesToScroll": 1 }'>
    <div class="hdt-slider__viewport hdt-yaman-hero__viewport">
      <div class="hdt-slider__container">
        {% content_for "blocks" %}
      </div>
    </div>
    {%- if section.settings.navUI -%}
      <div class="hdt-navigation hdt-position-default hdt-visible-{{ section.settings.nav_visible }} hdt-style-{{ section.settings.nav_style }} hdt-shape-{{ section.settings.nav_shape }} hdt-size-{{ section.settings.nav_size }} hdt-hide-mobile-{{ section.settings.nav_hide_mobile }}">
        <button aria-controls="Slider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--prev" type="button" disabled name="previous" aria-label="previous">
          <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M5.5 11L0 5.5L5.5 0L6.47625 0.97625L1.9525 5.5L6.47625 10.0238L5.5 11Z" fill="currentColor"/></svg>
        </button>
        <button aria-controls="Slider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--next" type="button" disabled name="next" aria-label="next">
          <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M1.5 11L7 5.5L1.5 0L0.52375 0.97625L5.0475 5.5L0.52375 10.0238L1.5 11Z" fill="currentColor"/></svg>
        </button>
      </div>
    {%- endif -%}
    {%- if section.settings.dotUI -%}
      <div hdt-slider-dots aria-controls="Slider-{{ section.id }}" class="hdt-slider__dots hdt-pagination hdt-yaman-hero__dots hdt-position-{{ section.settings.pag_position }} hdt-style-{{ section.settings.pag_style }} hdt-radius-{{ section.settings.pag_rounded }} hdt-hide-mobile-{{ section.settings.pag_hide_mobile }}" style="--space-between: {{ section.settings.pag_space }}px; --margin-top: {{ section.settings.pag_mgt }}px;" hdt-reveal="slide-in" timeline></div>
    {%- endif -%}
  </hdt-slideshow>
</div>
{% schema %}
{
  "name": "YAMAN Hero Slideshow",
  "tag": "section",
  "class": "hdt-slideshow-n hdt-slideshow hdt-section section-allow-transparent",
  "blocks": [{ "type": "_slide-item-n" }],
  "max_blocks": 5,
  "disabled_on": {
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Hero layout"
    },
    {
      "type": "range",
      "id": "hero_min_height",
      "min": 320,
      "max": 820,
      "step": 10,
      "unit": "px",
      "label": "Hero height (desktop)",
      "default": 560
    },
    {
      "type": "range",
      "id": "hero_image_height_mb",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Image height (mobile)",
      "info": "Height of the image shown below the black content panel on mobile.",
      "default": 340
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay (desktop)",
      "info": "Dark gradient over the image so the white text stays readable. Not used on mobile.",
      "default": 40
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "is_fade",
      "label": "Fade between slides",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay",
      "min": 0,
      "max": 7,
      "step": 0.5,
      "unit": "s",
      "label": "Auto-rotate every",
      "info": "Set to 0 to disable auto-rotate.",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "pauseOnHover",
      "label": "Pause on hover",
      "default": true,
      "visible_if": "{{ section.settings.autoplay > 0 }}"
    },
    {
      "type": "header",
      "content": "Navigation arrows"
    },
    {
      "type": "checkbox",
      "id": "navUI",
      "label": "Show arrows",
      "default": false
    },
    {
      "type": "select",
      "id": "nav_visible",
      "label": "Arrows visibility",
      "options": [
        { "value": "always", "label": "Always" },
        { "value": "hover", "label": "On hover" }
      ],
      "default": "hover",
      "visible_if": "{{ section.settings.navUI }}"
    },
    {
      "type": "select",
      "id": "nav_style",
      "label": "Arrows style",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "outline", "label": "Outline" },
        { "value": "simple", "label": "Simple" }
      ],
      "default": "default",
      "visible_if": "{{ section.settings.navUI }}"
    },
    {
      "type": "select",
      "id": "nav_shape",
      "label": "Arrows shape",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "rounded", "label": "Rounded" },
        { "value": "rotate", "label": "Rotate" }
      ],
      "default": "rounded",
      "visible_if": "{{ section.settings.nav_style != 'simple' and section.settings.navUI }}"
    },
    {
      "type": "select",
      "id": "nav_size",
      "label": "Arrows size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.navUI }}"
    },
    {
      "type": "checkbox",
      "id": "nav_hide_mobile",
      "label": "Hide arrows on mobile",
      "default": true,
      "visible_if": "{{ section.settings.navUI }}"
    },
    {
      "type": "header",
      "content": "Pagination dots"
    },
    {
      "type": "checkbox",
      "id": "dotUI",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "select",
      "id": "pag_style",
      "label": "Dots style",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "outline", "label": "Outline" },
        { "value": "elessi", "label": "Elessi" },
        { "value": "dot-outline", "label": "Dot outline" }
      ],
      "default": "default",
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "select",
      "id": "pag_position",
      "label": "Dots position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "checkbox",
      "id": "pag_rounded",
      "label": "Rounded dots",
      "default": true,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "range",
      "id": "pag_space",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Space between dots",
      "default": 10,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "range",
      "id": "pag_mgt",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Dots offset",
      "default": 20,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "checkbox",
      "id": "pag_hide_mobile",
      "label": "Hide dots on mobile",
      "default": false,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "checkbox",
      "id": "colors_by_section",
      "label": "Custom colors for this section",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "visible_if": "{{ section.settings.colors_by_section }}"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Background opacity",
      "default": 0,
      "visible_if": "{{ section.settings.colors_by_section }}"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "text",
      "id": "mg",
      "label": "Margin",
      "info": "Margin top, right, bottom, left. Leave a slot blank to skip it.",
      "default": ",,50px,",
      "placeholder": ",,50px,"
    },
    {
      "type": "text",
      "id": "mg_mb",
      "label": "Margin (mobile)",
      "default": ",,30px,",
      "placeholder": ",,30px,",
      "visible_if": "{{ section.settings.mg != blank }}"
    },
    {
      "type": "text",
      "id": "pd",
      "label": "Padding",
      "info": "Padding top, right, bottom, left. Leave a slot blank to skip it.",
      "placeholder": "50px,,50px,"
    },
    {
      "type": "text",
      "id": "pd_mb",
      "label": "Padding (mobile)",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.pd != blank }}"
    }
  ],
  "presets": [
    {
      "name": "YAMAN Hero Slideshow",
      "category": "t:sections_categories.01_hero.name",
      "blocks": [
        {
          "type": "_slide-item-n",
          "settings": {
            "heading": "LIFT.\nSCULPT.\nREDEFINE.",
            "heading_mb": "ELEVATE.\nSCULPT.\nREDEFINE.",
            "subheading": "<p>46 years of R&D. 345+ patents. Clinical-grade technology designed for you.</p>",
            "button_label": "SHOP MEDI LIFT PLUS — 1,700 SAR",
            "meta_text": "345+ PATENTS | ISO 13485 CERTIFIED | 10M+ UNITS SOLD"
          }
        },
        {
          "type": "_slide-item-n",
          "settings": {
            "heading": "FIRM.\nDEFINE.\nGLOW.",
            "subheading": "<p>Clinically proven results powered by Japanese R&D.</p>",
            "button_label": "EXPLORE THE 4 SETS",
            "meta_text": "SFDA CERTIFIED | CLINICALLY TESTED | FREE GCC DELIVERY"
          }
        },
        {
          "type": "_slide-item-n",
          "settings": {
            "heading": "YOUR\nDAILY\nRITUAL.",
            "subheading": "<p>Spa-grade skincare technology, designed for home.</p>",
            "button_label": "DISCOVER YOUR GLOW",
            "meta_text": "30-DAY RETURNS | 10M+ UNITS SOLD | TRUSTED WORLDWIDE"
          }
        }
      ]
    }
  ]
}
{% endschema %}
