<!-- section/science-slideshow-n.liquid — YAMAN "Science Behind the Glow" (duplicated from slideshow.liquid) -->
{{ 'slideshow.css' | asset_url | stylesheet_tag: media: 'all' }}
{%- style -%}
  {%- render 'spacing-vars', box: section -%}
{%- endstyle -%}
<div
  class="hdt-yaman-science-section hdt-section-spacing hdt-section-spacing-{{ section.id }} hdt-s-gradient"
  {%- unless section.index == 1 %} hdt-reveal="fade-in"{%- endunless %}
  style="--sci-radius: {{ section.settings.card_radius }}px; --sci-ov: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; --sci-ar-dk: {{ section.settings.card_ratio_dk | default: 215 }}; --sci-ar-tb: {{ section.settings.card_ratio_tb | default: 155 }}; --sci-ar-mb-lg: {{ section.settings.card_ratio_mb_lg | default: 130 }}; --sci-ar-mb: {{ section.settings.card_ratio_mb | default: 70 }}; --sci-w-dk: {{ section.settings.slide_width_dk }}%; --sci-w-tb: {{ section.settings.slide_width_tb }}%; --sci-w-mb: {{ section.settings.slide_width_mb }}%; --sci-gap: {{ section.settings.gap }}px; --sci-gap-mb: {{ section.settings.gap_mb }}px; --sci-pt: {{ section.settings.padding_top }}px; --sci-pb: {{ section.settings.padding_bottom }}px; --sci-pt-mb: {{ section.settings.padding_top_mb }}px; --sci-pb-mb: {{ section.settings.padding_bottom_mb }}px;"
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="hdt-yaman-science__header hdt-container">
      {%- if section.settings.heading != blank -%}
        <h2 class="hdt-yaman-science__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hdt-yaman-science__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <hdt-slideshow
    id="Slider-{{ section.id }}"
    autoheight
    class="hdt-slider hdt-relative hdt-container hdt-slideshow hdt-slides-1 hdt-yaman-science"
    config='{"loop": {{ section.settings.loop }}, "navUI": {{ section.settings.navUI }}, "dotUI": {{ section.settings.dotUI }}, "autoPlay": {{ section.settings.autoplay | times: 1000 }}, "pauseOnHover": {{ section.settings.pauseOnHover }}, "autoHeight": true, "slidesToScroll": 1 }'
  >
    <div class="hdt-slider__viewport">
      <div class="hdt-slider__container">
        {% content_for "blocks" %}
      </div>
    </div>
    {%- if section.settings.navUI -%}
      <div class="hdt-navigation hdt-position-default hdt-visible-{{ section.settings.nav_visible }} hdt-style-default hdt-shape-rounded hdt-size-small hdt-hide-mobile-false">
        <button aria-controls="Slider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--prev" type="button" disabled name="previous" aria-label="previous">
          <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M5.5 11L0 5.5L5.5 0L6.47625 0.97625L1.9525 5.5L6.47625 10.0238L5.5 11Z" fill="currentColor"/></svg>
        </button>
        <button aria-controls="Slider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--next" type="button" disabled name="next" aria-label="next">
          <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M1.5 11L7 5.5L1.5 0L0.52375 0.97625L5.0475 5.5L0.52375 10.0238L1.5 11Z" fill="currentColor"/></svg>
        </button>
      </div>
    {%- endif -%}
    {%- if section.settings.dotUI -%}
      <div hdt-slider-dots aria-controls="Slider-{{ section.id }}" class="hdt-slider__dots hdt-pagination hdt-position-{{ section.settings.pag_position }} hdt-style-default hdt-radius-{{ section.settings.pag_rounded }} hdt-hide-mobile-false" style="--space-between: {{ section.settings.pag_space }}px; --margin-top: {{ section.settings.pag_mgt }}px;" hdt-reveal="slide-in" timeline></div>
    {%- endif -%}
  </hdt-slideshow>
</div>
{% schema %}
{
  "name": "YAMAN Science",
  "tag": "section",
  "class": "hdt-section hdt-yaman-science-wrap section-allow-transparent",
  "blocks": [{ "type": "_science-slide-item-n" }],
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Science Behind the Glow"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "46 years of Japanese R&D — engineered into every device."
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 24
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Overlay opacity",
      "info": "Darkening behind the text for readability.",
      "default": 45
    },
    {
      "type": "range",
      "id": "card_ratio_dk",
      "min": 120,
      "max": 300,
      "step": 5,
      "label": "Card ratio — desktop",
      "info": "Width ÷ height × 100. Higher = wider/shorter. 215 ≈ Figma.",
      "default": 215
    },
    {
      "type": "range",
      "id": "card_ratio_tb",
      "min": 100,
      "max": 240,
      "step": 5,
      "label": "Card ratio — tablet",
      "info": "Higher = wider/shorter. 155 ≈ balanced middle.",
      "default": 155
    },
    {
      "type": "range",
      "id": "card_ratio_mb_lg",
      "min": 80,
      "max": 200,
      "step": 5,
      "label": "Card ratio — large phone (471–767px)",
      "info": "Higher = wider/shorter. Keeps mid-size screens from getting too tall.",
      "default": 130
    },
    {
      "type": "range",
      "id": "card_ratio_mb",
      "min": 50,
      "max": 160,
      "step": 5,
      "label": "Card ratio — phone (≤470px)",
      "info": "Below 100 = taller than wide (portrait). 70 ≈ Figma.",
      "default": 70
    },
    {
      "type": "header",
      "content": "Carousel layout"
    },
    {
      "type": "range",
      "id": "slide_width_dk",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Card width — desktop",
      "info": "Less than 100% reveals part of the next card.",
      "default": 88
    },
    {
      "type": "range",
      "id": "slide_width_tb",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Card width — tablet",
      "default": 72
    },
    {
      "type": "range",
      "id": "slide_width_mb",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Card width — mobile",
      "default": 85
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap_mb",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards (mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Carousel behavior"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay",
      "min": 0,
      "max": 7,
      "step": 0.5,
      "unit": "s",
      "label": "Autoplay",
      "info": "0 = off.",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "pauseOnHover",
      "label": "Pause on hover",
      "default": true,
      "visible_if": "{{ section.settings.autoplay > 0 }}"
    },
    {
      "type": "checkbox",
      "id": "navUI",
      "label": "Show arrows",
      "default": false
    },
    {
      "type": "select",
      "id": "nav_visible",
      "label": "Arrows visibility",
      "options": [
        { "value": "always", "label": "Always" },
        { "value": "hover", "label": "On hover" }
      ],
      "default": "hover",
      "visible_if": "{{ section.settings.navUI }}"
    },
    {
      "type": "checkbox",
      "id": "dotUI",
      "label": "Show dots",
      "default": false
    },
    {
      "type": "select",
      "id": "pag_position",
      "label": "Dots position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "checkbox",
      "id": "pag_rounded",
      "label": "Rounded dots",
      "default": true,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "range",
      "id": "pag_space",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Dot spacing",
      "default": 10,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "range",
      "id": "pag_mgt",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Dots top margin",
      "default": 16,
      "visible_if": "{{ section.settings.dotUI }}"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "YAMAN Science",
      "category": "t:sections_categories.05_section.name",
      "blocks": [
        {
          "type": "_science-slide-item-n",
          "settings": {
            "title": "DYHP — Dynamic Hydro-Pressure",
            "description": "Gentle suction and micro-vibration deeply cleanse pores, remove dead skin cells, and infuse active ingredients directly into the skin — leaving a visibly brighter, smoother complexion after every use.",
            "tag_1": "DEEP CLEANSE",
            "tag_2": "PORE REFINEMENT",
            "tag_3": "INSTANT GLOW",
            "used_in": "Used in: Hydra Bright Skin Set"
          }
        },
        {
          "type": "_science-slide-item-n",
          "settings": {
            "title": "EMS — Electrical Muscle Stimulation",
            "description": "Low-frequency electrical pulses gently activate facial muscles, helping to lift, firm and tone — for a more sculpted, defined contour with continued use.",
            "tag_1": "MUSCLE LIFTING",
            "tag_2": "ZERO UV",
            "tag_3": "HANDS-FREE",
            "used_in": "Used in: Medi Lift Plus / Liftology SP"
          }
        },
        {
          "type": "_science-slide-item-n",
          "settings": {
            "title": "Radio Frequency (RF)",
            "description": "RF energy penetrates deep into the dermis, generating controlled heat that triggers collagen and elastin production — for visibly firmer, lifted skin that improves with each session.",
            "tag_1": "ALL SKIN LAYERS",
            "tag_2": "COLLAGEN BOOST",
            "tag_3": "DEEP DERMIS",
            "used_in": "Used in: Photo Plus S+ / Liftology SP"
          }
        },
        {
          "type": "_science-slide-item-n",
          "settings": {
            "title": "Photon LED Light Therapy",
            "description": "Multi-wavelength LED targets different skin concerns at the cellular level — red light boosts collagen, blue light targets blemish-causing bacteria, yellow light soothes — with zero UV and zero downtime.",
            "tag_1": "MULTI-WAVELENGTH",
            "tag_2": "ZERO UV",
            "tag_3": "CELLULAR RENEWAL",
            "used_in": "Used in: Photo Plus Prestige SP"
          }
        }
      ]
    }
  ]
}
{% endschema %}
