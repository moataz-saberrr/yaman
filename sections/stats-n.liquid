    "name": "YAMAN Stats",
    "tag": "section",
    "class": "hdt-section hdt-yaman-stats-section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings": [
      {
        "type": "header",
        "content": "Stat 1"
      },
      {
        "type": "text",
        "id": "stat_1_number",
        "label": "Number",
        "default": "93"
      },
      {
        "type": "text",
        "id": "stat_1_suffix",
        "label": "Suffix",
        "default": "%"
      },
      {
        "type": "text",
        "id": "stat_1_label",
        "label": "Label",
        "default": "Firmer Skin"
      }, {
