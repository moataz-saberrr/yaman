<!-- stats-n.liquid — YAMAN Stats row (settings-only; adapted from custom-section.liquid pattern) -->
{%- liquid
  assign st_bg = section.settings.background_color
  assign st_text = section.settings.text_color
  assign st_divider = section.settings.divider_color
-%}
<div
  class="hdt-yaman-stats"
  id="hdt-yaman-stats-{{ section.id }}"
  hdt-reveal="fade-in"
  style="--st-bg: {{ st_bg }}; --st-text: {{ st_text }}; --st-divider: {{ st_divider }}; --st-maxw: {{ section.settings.container_max_width }}px; --st-value: {{ section.settings.value_size }}px; --st-value-mb: {{ section.settings.value_size_mb }}px; --st-label: {{ section.settings.label_size }}px; --st-pt: {{ section.settings.padding_top }}px; --st-pb: {{ section.settings.padding_bottom }}px; --st-pt-mb: {{ section.settings.padding_top_mb }}px; --st-pb-mb: {{ section.settings.padding_bottom_mb }}px;">
  <div class="hdt-yaman-stats__container">
    <div class="hdt-yaman-stats__grid">
      {%- for i in (1..4) -%}
        {%- liquid
          assign num_key = 'stat_' | append: i | append: '_number'
          assign suf_key = 'stat_' | append: i | append: '_suffix'
          assign lbl_key = 'stat_' | append: i | append: '_label'
          assign s_num = section.settings[num_key]
          assign s_suf = section.settings[suf_key]
          assign s_lbl = section.settings[lbl_key]
        -%}
        <div class="hdt-yaman-stats__item">
          <div class="hdt-yaman-stats__value">{{ s_num }}{%- if s_suf != blank -%}
              <span class="hdt-yaman-stats__suffix">{{ s_suf }}</span>
            {%- endif -%}
          </div>
          {%- if s_lbl != blank -%}
            <div class="hdt-yaman-stats__label">{{ s_lbl }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>
{% schema %}
