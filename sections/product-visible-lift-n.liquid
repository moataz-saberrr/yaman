<!-- product-visible-lift-n.liquid — YAMAN product-page "Visible Lift" section
  2-col: dynamic left content + interactive before/after gallery (up to 5 pairs).
  CSS: assets/custom_yaman_dev2.css (scoped .product .hdt-product-visible-lift-section)
  JS: assets/product-visible-lift-n.js (scoped, native pointer drag, no library) -->
{%- liquid
  assign pos = section.settings.default_position | default: 50

  # collect indices of pairs that have at least one image, so an empty pair never breaks the gallery
  assign valid = ''
  for i in (1..5)
    assign bkey = 'pair_' | append: i | append: '_before'
    assign akey = 'pair_' | append: i | append: '_after'
    if section.settings[bkey] != blank or section.settings[akey] != blank
      assign valid = valid | append: i | append: ','
    endif
  endfor
  assign valid = valid | split: ','
-%}
<div
  class="hdt-product-visible-lift"
  id="hdt-product-visible-lift-{{ section.id }}"
  style="--vl-bg: {{ section.settings.background_color }}; --vl-stats-bg: {{ section.settings.stats_bg }}; --vl-accent: {{ section.settings.accent_color }}; --vl-maxw: {{ section.settings.container_max_width }}px; --vl-radius: {{ section.settings.main_radius }}px; --vl-pt: {{ section.settings.padding_top }}px; --vl-pb: {{ section.settings.padding_bottom }}px; --vl-pt-mb: {{ section.settings.padding_top_mb }}px; --vl-pb-mb: {{ section.settings.padding_bottom_mb }}px;">
  <div class="hdt-product-visible-lift__container">

    <!-- LEFT: dynamic content -->
    <div class="hdt-product-visible-lift__content">
      <div class="hdt-product-visible-lift__text-content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hdt-product-visible-lift__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hdt-product-visible-lift__heading">{{ section.settings.heading | escape | newline_to_br }}</h2>
        {%- endif -%}
        {%- if section.settings.study != blank -%}
          <p class="hdt-product-visible-lift__study">{{ section.settings.study }}</p>
        {%- endif -%}
      </div>

      <div class="hdt-product-visible-lift__stats">
        {%- for i in (1..4) -%}
          {%- assign nkey = 'stat_' | append: i | append: '_number' -%}
          {%- assign tkey = 'stat_' | append: i | append: '_text' -%}
          <div class="hdt-product-visible-lift__stat">
            <span class="hdt-product-visible-lift__stat-value">{{ section.settings[nkey] }}</span>
            {%- if section.settings[tkey] != blank -%}
              <span class="hdt-product-visible-lift__stat-text">{{ section.settings[tkey] }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.note != blank -%}
        <p class="hdt-product-visible-lift__note">{{ section.settings.note | escape | newline_to_br }}</p>
      {%- endif -%}
    </div>

    <!-- RIGHT: before/after gallery -->
    <div class="hdt-product-visible-lift__gallery">
      <div class="hdt-product-visible-lift__main" data-vl-main>
        {%- if valid.size > 0 -%}
          {%- for idx in valid -%}
            {%- liquid
              assign bkey = 'pair_' | append: idx | append: '_before'
              assign akey = 'pair_' | append: idx | append: '_after'
              assign balt = 'pair_' | append: idx | append: '_before_alt'
              assign aalt = 'pair_' | append: idx | append: '_after_alt'
              assign bimg = section.settings[bkey]
              assign aimg = section.settings[akey]
              assign before_alt = section.settings[balt] | default: 'Before'
              assign after_alt = section.settings[aalt] | default: 'After'
            -%}
            <div class="hdt-product-visible-lift__ba-slide{% if forloop.first %} is-active{% endif %}" data-vl-slide="{{ idx }}">
              <div
                class="hdt-product-visible-lift__before-after"
                data-vl-ba
                style="--vl-pos: {{ pos }}%;">
                <div class="hdt-product-visible-lift__image hdt-product-visible-lift__after">
                  {%- if aimg != blank -%}
                    {{ aimg | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'hdt-product-visible-lift__img', alt: after_alt, widths: '300,500,700,900,1116', sizes: '(max-width: 991px) 90vw, 558px' }}
                  {%- else -%}
                    <div class="hdt-product-visible-lift__placeholder hdt-product-visible-lift__placeholder--after" aria-hidden="true"></div>
                  {%- endif -%}
                </div>
                <div class="hdt-product-visible-lift__image hdt-product-visible-lift__before" aria-hidden="true">
                  {%- if bimg != blank -%}
                    {{ bimg | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'hdt-product-visible-lift__img', alt: before_alt, widths: '300,500,700,900,1116', sizes: '(max-width: 991px) 90vw, 558px' }}
                  {%- else -%}
                    <div class="hdt-product-visible-lift__placeholder hdt-product-visible-lift__placeholder--before"></div>
                  {%- endif -%}
                </div>

                <span class="hdt-product-visible-lift__label hdt-product-visible-lift__label--before">{{ section.settings.before_label | default: 'Before' }}</span>
                <span class="hdt-product-visible-lift__label hdt-product-visible-lift__label--after">{{ section.settings.after_label | default: 'After' }}</span>

                <span class="hdt-product-visible-lift__divider" aria-hidden="true"></span>
                <div
                  class="hdt-product-visible-lift__handle"
                  data-vl-handle
                  role="slider"
                  tabindex="0"
                  aria-label="Drag to compare before and after"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-valuenow="{{ pos }}">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    aria-hidden="true"><path
                      d="M9 7l-5 5 5 5M15 7l5 5-5 5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round" /></svg>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="hdt-product-visible-lift__ba-slide is-active" data-vl-slide="0">
            <div
              class="hdt-product-visible-lift__before-after"
              data-vl-ba
              style="--vl-pos: {{ pos }}%;">
              <div class="hdt-product-visible-lift__image hdt-product-visible-lift__after">
                <div class="hdt-product-visible-lift__placeholder hdt-product-visible-lift__placeholder--after" aria-hidden="true"></div>
              </div>
              <div class="hdt-product-visible-lift__image hdt-product-visible-lift__before" aria-hidden="true">
                <div class="hdt-product-visible-lift__placeholder hdt-product-visible-lift__placeholder--before"></div>
              </div>
              <span class="hdt-product-visible-lift__label hdt-product-visible-lift__label--before">{{ section.settings.before_label | default: 'Before' }}</span>
              <span class="hdt-product-visible-lift__label hdt-product-visible-lift__label--after">{{ section.settings.after_label | default: 'After' }}</span>
              <span class="hdt-product-visible-lift__divider" aria-hidden="true"></span>
              <div
                class="hdt-product-visible-lift__handle"
                data-vl-handle
                role="slider"
                tabindex="0"
                aria-label="Drag to compare before and after"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="{{ pos }}">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"><path
                    d="M9 7l-5 5 5 5M15 7l5 5-5 5"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round" /></svg>
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- if valid.size > 1 -%}
        <div class="hdt-product-visible-lift__thumbs" data-vl-thumbs>
          {%- for idx in valid -%}
            {%- liquid
              assign bkey = 'pair_' | append: idx | append: '_before'
              assign akey = 'pair_' | append: idx | append: '_after'
              assign bimg = section.settings[bkey]
              assign aimg = section.settings[akey]
            -%}
            <button
              type="button"
              class="hdt-product-visible-lift__thumb{% if forloop.first %} is-hidden{% endif %}"
              data-vl-thumb="{{ idx }}"
              aria-label="Show result {{ forloop.index }}">
              <span class="hdt-product-visible-lift__thumb-ba">
                <span class="hdt-product-visible-lift__image hdt-product-visible-lift__after">
                  {%- if aimg != blank -%}
                    {{ aimg | image_url: width: 280 | image_tag: loading: 'lazy', class: 'hdt-product-visible-lift__img', alt: '', widths: '120,180,240,320' }}
                  {%- else -%}
                    <span class="hdt-product-visible-lift__placeholder hdt-product-visible-lift__placeholder--after"></span>
                  {%- endif -%}
                </span>
                <span class="hdt-product-visible-lift__image hdt-product-visible-lift__before" aria-hidden="true">
                  {%- if bimg != blank -%}
                    {{ bimg | image_url: width: 280 | image_tag: loading: 'lazy', class: 'hdt-product-visible-lift__img', alt: '', widths: '120,180,240,320' }}
                  {%- else -%}
                    <span class="hdt-product-visible-lift__placeholder hdt-product-visible-lift__placeholder--before"></span>
                  {%- endif -%}
                </span>
                <span class="hdt-product-visible-lift__thumb-divider" aria-hidden="true"></span>
              </span>
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<script src="{{ 'product-visible-lift-n.js' | asset_url }}" defer></script>

{% schema %}
