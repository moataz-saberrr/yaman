<!-- section/yaman-routine-steps-n.liquid — YAMAN Steps: "Four steps to lifted, sculpted skin."
     Product-page routine steps. Built from scratch (no close Kalles base). Centred header +
     responsive grid of image cards (4-across desktop, 2x2 mobile). No carousel.
     CSS: assets/custom_yaman_dev4.css (loaded globally from layout/theme.liquid). -->
<div
  class="hdt-yaman-steps"
  style="
    --st-bg: {{ section.settings.background_color }};
    --st-maxw: {{ section.settings.container_max_width }}px;
    --st-pad-x: {{ section.settings.container_padding }}px;
    --st-gap: {{ section.settings.gap }}px;
    --st-gap-mb: {{ section.settings.gap_mb }}px;
    --st-radius: {{ section.settings.card_radius }}px;
    --st-ov: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --st-heading: {{ section.settings.heading_color }};
    --st-accent: {{ section.settings.accent_color }};
    --st-cols: {{ section.settings.cols_dk | default: 4 }};
    --st-pt: {{ section.settings.padding_top }}px;
    --st-pb: {{ section.settings.padding_bottom }}px;
    --st-pt-mb: {{ section.settings.padding_top_mb }}px;
    --st-pb-mb: {{ section.settings.padding_bottom_mb }}px;
  "
>
  <div class="hdt-yaman-steps__container">
    <div class="hdt-yaman-steps__header">
      {%- if section.settings.icon != blank -%}
        <div class="hdt-yaman-steps__icon">
          {{ section.settings.icon | image_url: width: 120 | image_tag: loading: 'lazy', widths: '28,56,84,120', alt: section.settings.eyebrow }}
        </div>
      {%- else -%}
        <div class="hdt-yaman-steps__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="14" cy="15" r="10" stroke="currentColor" stroke-width="1.4"/>
            <path d="M14 9.5V15l3.5 2.2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10.5 3.5h7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank -%}
        <p class="hdt-yaman-steps__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="hdt-yaman-steps__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="hdt-yaman-steps__text">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="hdt-yaman-steps__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign st_img = block.settings.image
          assign st_alt = block.settings.alt | default: block.settings.title
        -%}
        <div class="hdt-yaman-steps__card" {{ block.shopify_attributes }}>
          <div class="hdt-yaman-steps__image">
            {%- if st_img != blank -%}
              {{ st_img | image_url: width: 800 | image_tag: loading: 'lazy', alt: st_alt, widths: '300,400,600,800', sizes: '(max-width: 767px) 50vw, 25vw' }}
            {%- else -%}
              <span class="hdt-yaman-steps__placeholder" aria-hidden="true"></span>
            {%- endif -%}
          </div>
          <span class="hdt-yaman-steps__overlay" aria-hidden="true"></span>
          <div class="hdt-yaman-steps__content">
            {%- if block.settings.number != blank -%}
              <span class="hdt-yaman-steps__number">{{ block.settings.number }}</span>
            {%- endif -%}
            <div class="hdt-yaman-steps__body">
              {%- if block.settings.title != blank -%}
                <h3 class="hdt-yaman-steps__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="hdt-yaman-steps__description">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.time != blank -%}
                <span class="hdt-yaman-steps__time">{{ block.settings.time }}</span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- comment -%} custom_yaman_dev4.css is loaded globally from layout/theme.liquid — nothing to load here. {%- endcomment -%}

{% schema %}
{
  "name": "YAMAN Steps",
  "tag": "section",
  "class": "hdt-yaman-steps-section hdt-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Top icon",
      "info": "Small centered icon. Leave empty to use a built-in clock icon."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "YOUR 12-MINUTE ROUTINE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Four steps to lifted, sculpted skin."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Designed to fit your morning without interruption."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF6F0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & text color",
      "default": "#1D2847"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Time accent color",
      "default": "#D4B87A"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Image overlay opacity",
      "info": "Darkening at the bottom of each card for text readability.",
      "default": 60
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 960,
      "max": 1600,
      "step": 10,
      "unit": "px",
      "label": "Container max width",
      "default": 1310
    },
    {
      "type": "range",
      "id": "container_padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "select",
      "id": "cols_dk",
      "label": "Cards per row (desktop)",
      "default": "4",
      "options": [
        { "label": "2", "value": "2" },
        { "label": "3", "value": "3" },
        { "label": "4", "value": "4" }
      ]
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Card corner radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Card gap (desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap_mb",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Card gap (mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cleanse"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this step in a sentence or two."
        },
        {
          "type": "text",
          "id": "time",
          "label": "Time",
          "default": "2 MIN"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text",
          "info": "Defaults to the title if left empty."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "YAMAN Steps",
      "category": "YAMAN",
      "blocks": [
        { "type": "step", "settings": { "number": "01", "title": "Cleanse", "time": "2 MIN", "description": "Start with a clean, dry face. Skin contact ensures optimal conductivity for every session." } },
        { "type": "step", "settings": { "number": "02", "title": "Lift", "time": "6 MIN", "description": "Apply a generous layer of YĀMAN Lifting Gel. Glide the device upward along jaw, cheek, and brow — RF + EMS active." } },
        { "type": "step", "settings": { "number": "03", "title": "Sculpt", "time": "3 MIN", "description": "Switch to sculpt mode for under-eye and forehead detail work. Target fine lines and hollows." } },
        { "type": "step", "settings": { "number": "04", "title": "Glow", "time": "1 MIN", "description": "Finish with Photon LED to support cellular renewal and skin radiance overnight." } }
      ]
    }
  ]
}
{% endschema %}
