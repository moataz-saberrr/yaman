{%- comment -%}
  sections/product-hero-banner-n.liquid — Product page hero / banner slider.

  Full-bleed composed background image per slide (separate desktop + mobile image that
  already contain the product + empty space for copy). Content (static star rating, heading,
  two description lines, and up to 6 badge/tab chips) is overlaid on the empty area:
  desktop → right side / vertically centered; mobile → top / centered.

  Reuses the theme's built-in Kalles <hdt-slideshow> slider (arrows/dots/loop/autoplay via
  config) — NO custom JS. Structure/settings extend the proven `yaman-mode-banner-n` pattern.

  Scope class: .hdt-product-hero-banner-section
  CSS: assets/custom-productza.css  (scoped under `.product .hdt-product-hero-banner-section`)
{%- endcomment -%}

{{ 'custom-productza.css' | asset_url | stylesheet_tag: media: 'all' }}
{{ 'slideshow.css' | asset_url | stylesheet_tag: media: 'all' }}

{%- liquid
  assign count = section.blocks.size

  assign show_arrows = false
  if section.settings.enable_arrows and count > 1
    assign show_arrows = true
  endif

  assign show_dots = false
  if section.settings.enable_dots and count > 1
    assign show_dots = true
  endif

  assign hide_arrows_mb = section.settings.hide_arrows_mobile
  assign hide_dots_mb = section.settings.hide_dots_mobile

  assign autoplay_ms = 0
  if section.settings.autoplay
    assign autoplay_ms = section.settings.autoplay_speed | times: 1000
  endif

  assign auto_height = false
  if section.settings.height_mode == 'adapt' or section.settings.height_mode_mb == 'adapt'
    assign auto_height = true
  endif

  assign root_class = 'hdt-product-hero-banner hdt-product-hero-banner-dk--' | append: section.settings.height_mode
  assign root_class = root_class | append: ' hdt-product-hero-banner-mb--' | append: section.settings.height_mode_mb
  if section.settings.full_width
    assign root_class = root_class | append: ' hdt-product-hero-banner--full'
  endif
  if section.settings.custom_class != blank
    assign root_class = root_class | append: ' ' | append: section.settings.custom_class
  endif
-%}

<div
  class="{{ root_class }}"
  id="ProductHeroBanner-{{ section.id }}"
  style="
    --phb-bg: {{ section.settings.background_color }};
    --phb-maxw: {{ section.settings.container_max_width }}px;
    --phb-h: {{ section.settings.height }}px;
    --phb-h-tb: {{ section.settings.height_tablet }}px;
    --phb-h-mb: {{ section.settings.height_mb }}px;
    --phb-ovc: {{ section.settings.overlay_color }};
    --phb-ov: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --phb-arrow: {{ section.settings.arrow_color }};
    --phb-arrow-bg: {{ section.settings.arrow_bg }};
    --phb-pt: {{ section.settings.padding_top }}px;
    --phb-pb: {{ section.settings.padding_bottom }}px;
    --phb-pt-mb: {{ section.settings.padding_top_mb }}px;
    --phb-pb-mb: {{ section.settings.padding_bottom_mb }}px;
  "
>
  {%- if count > 0 -%}
    {%- capture star_svg -%}<svg class="hdt-product-hero-banner__star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.6l2.74 5.55 6.13.9-4.43 4.32 1.05 6.1L12 16.9 6.51 19.6l1.05-6.1L3.13 9.05l6.13-.9L12 2.6z" fill="currentColor"/></svg>{%- endcapture -%}

    <hdt-slideshow
      id="PhbSlider-{{ section.id }}"
      class="hdt-product-hero-banner__slider hdt-slider hdt-relative hdt-slideshow hdt-slides-1"
      config='{"loop": {{ section.settings.loop }}, "navUI": {{ show_arrows }}, "dotUI": {{ show_dots }}, "autoPlay": {{ autoplay_ms }}, "pauseOnHover": true, "autoHeight": {{ auto_height }}, "slidesToScroll": 1 }'
    >
      <div class="hdt-product-hero-banner__viewport hdt-slider__viewport hdt-relative">
        <div class="hdt-slider__container">
          {%- for block in section.blocks -%}
            {%- liquid
              assign img = block.settings.image
              assign img_mb = block.settings.image_mobile
              assign alt = block.settings.image_alt | default: block.settings.heading

              # ---- static star rating ----
              assign val = block.settings.rating_value | times: 1.0
              assign mx = block.settings.rating_max | times: 1.0
              if mx <= 0
                assign mx = 5.0
              endif
              assign pct = val | divided_by: mx | times: 100
              if pct > 100
                assign pct = 100
              endif
              if pct < 0
                assign pct = 0
              endif

              # ---- map text-align -> flex justify for the rating/badge rows ----
              assign just = 'flex-start'
              case block.settings.text_align
                when 'center'
                  assign just = 'center'
                when 'end'
                  assign just = 'flex-end'
              endcase
              assign just_mb = 'center'
              case block.settings.text_align_mobile
                when 'start'
                  assign just_mb = 'flex-start'
                when 'end'
                  assign just_mb = 'flex-end'
              endcase

              # ---- per-slide style vars ----
              assign slide_style = ''
              assign slide_style = slide_style | append: '--phb-just:' | append: just | append: ';'
              assign slide_style = slide_style | append: '--phb-just-mb:' | append: just_mb | append: ';'
              assign slide_style = slide_style | append: '--phb-pos:' | append: block.settings.content_position | append: ';'
              assign slide_style = slide_style | append: '--phb-valign:' | append: block.settings.content_valign | append: ';'
              assign slide_style = slide_style | append: '--phb-align:' | append: block.settings.text_align | append: ';'
              assign slide_style = slide_style | append: '--phb-pos-mb:' | append: block.settings.content_position_mobile | append: ';'
              assign slide_style = slide_style | append: '--phb-align-mb:' | append: block.settings.text_align_mobile | append: ';'
              assign slide_style = slide_style | append: '--phb-content-maxw:' | append: block.settings.content_max_width | append: 'px;'
              assign slide_style = slide_style | append: '--phb-content-maxw-mb:' | append: block.settings.content_max_width_mb | append: 'px;'
              assign slide_style = slide_style | append: '--phb-focal:' | append: block.settings.focal_desktop | append: ';'
              assign slide_style = slide_style | append: '--phb-focal-mb:' | append: block.settings.focal_mobile | append: ';'
              assign slide_style = slide_style | append: '--phb-star:' | append: block.settings.rating_color | append: ';'
              assign slide_style = slide_style | append: '--phb-rating-text:' | append: block.settings.rating_text_color | append: ';'
              if block.settings.heading_color != blank
                assign slide_style = slide_style | append: '--phb-heading:' | append: block.settings.heading_color | append: ';'
              endif
              if block.settings.text_color != blank
                assign slide_style = slide_style | append: '--phb-text:' | append: block.settings.text_color | append: ';'
              endif
              assign slide_style = slide_style | append: '--phb-badge-bg:' | append: block.settings.badge_bg | append: ';'
              assign slide_style = slide_style | append: '--phb-badge-text:' | append: block.settings.badge_text_color | append: ';'
              assign slide_style = slide_style | append: '--phb-badge-bd:' | append: block.settings.badge_border_color | append: ';'
              if block.settings.use_overlay_override
                assign ov_slide = block.settings.overlay_opacity | divided_by: 100.0
                assign slide_style = slide_style | append: '--phb-ov:' | append: ov_slide | append: ';'
                if block.settings.overlay_color != blank
                  assign slide_style = slide_style | append: '--phb-ovc:' | append: block.settings.overlay_color | append: ';'
                endif
              endif
            -%}
            <div
              class="hdt-slider__slide hdt-product-hero-banner__slide"
              style="{{ slide_style }}"
              {{ block.shopify_attributes }}
            >
              <div class="hdt-product-hero-banner__media">
                {%- if img != blank -%}
                  <picture>
                    {%- if img_mb != blank -%}
                      <source media="(max-width: 767px)" srcset="{{ img_mb | image_url: width: 1200 }}, {{ img_mb | image_url: width: 1600 }} 1.5x">
                    {%- endif -%}
                    {{ img | image_url: width: 2000 | image_tag: class: 'hdt-product-hero-banner__image', alt: alt, loading: 'eager', fetchpriority: 'high', widths: '800,1200,1600,2000,2400', sizes: '100vw' }}
                  </picture>
                {%- else -%}
                  <div class="hdt-product-hero-banner__image hdt-product-hero-banner__placeholder" aria-hidden="true"></div>
                {%- endif -%}
                <div class="hdt-product-hero-banner__overlay" aria-hidden="true"></div>
              </div>

              <div class="hdt-product-hero-banner__content">
                <div class="hdt-product-hero-banner__container">
                  <div class="hdt-product-hero-banner__content-inner">
                    {%- if block.settings.rating_show -%}
                      <div class="hdt-product-hero-banner__rating">
                        <span class="hdt-product-hero-banner__stars" style="--phb-star-pct: {{ pct }}%;" role="img" aria-label="{{ block.settings.rating_value }} / {{ block.settings.rating_max }}">
                          <span class="hdt-product-hero-banner__stars-track">{%- for i in (1..5) -%}{{ star_svg }}{%- endfor -%}</span>
                          <span class="hdt-product-hero-banner__stars-fill">{%- for i in (1..5) -%}{{ star_svg }}{%- endfor -%}</span>
                        </span>
                        {%- if block.settings.rating_value != blank -%}
                          <span class="hdt-product-hero-banner__rating-score">{{ block.settings.rating_value | escape }}</span>
                        {%- endif -%}
                        {%- if block.settings.rating_text != blank -%}
                          <span class="hdt-product-hero-banner__rating-text">{{ block.settings.rating_text | escape }}</span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if block.settings.heading != blank -%}
                      <h2 class="hdt-product-hero-banner__heading">{{ block.settings.heading | escape }}</h2>
                    {%- endif -%}

                    {%- if block.settings.text_1 != blank -%}
                      <div class="hdt-product-hero-banner__description hdt-product-hero-banner__description--1">{{ block.settings.text_1 }}</div>
                    {%- endif -%}
                    {%- if block.settings.text_2 != blank -%}
                      <div class="hdt-product-hero-banner__description hdt-product-hero-banner__description--2">{{ block.settings.text_2 }}</div>
                    {%- endif -%}

                    {%- capture badges_html -%}
                      {%- for i in (1..6) -%}
                        {%- capture t_key -%}badge_{{ i }}_text{%- endcapture -%}
                        {%- capture svg_key -%}badge_{{ i }}_svg{%- endcapture -%}
                        {%- capture img_key -%}badge_{{ i }}_image{%- endcapture -%}
                        {%- capture link_key -%}badge_{{ i }}_link{%- endcapture -%}
                        {%- assign b_text = block.settings[t_key] -%}
                        {%- assign b_svg = block.settings[svg_key] -%}
                        {%- assign b_img = block.settings[img_key] -%}
                        {%- assign b_link = block.settings[link_key] -%}
                        {%- if b_text != blank -%}
                          {%- if b_link != blank -%}<a href="{{ b_link }}" class="hdt-product-hero-banner__badge">{%- else -%}<span class="hdt-product-hero-banner__badge">{%- endif -%}
                            {%- if b_text != blank -%}<span class="hdt-product-hero-banner__badge-text">{{ b_text | escape }}</span>{%- endif -%}
                            {%- if b_svg != blank -%}<span class="hdt-product-hero-banner__badge-icon">{{ b_svg }}</span>
                            {%- elsif b_img != blank -%}<span class="hdt-product-hero-banner__badge-icon"><img src="{{ b_img | image_url: width: 48 }}" alt="{{ b_text | escape }}" width="20" height="20" loading="lazy"></span>{%- endif -%}
                          {%- if b_link != blank -%}</a>{%- else -%}</span>{%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endcapture -%}
                    {%- assign badges_html = badges_html | strip -%}
                    {%- if badges_html != blank -%}
                      <div class="hdt-product-hero-banner__badges">{{ badges_html }}</div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- if show_arrows -%}
        <div class="hdt-product-hero-banner__nav hdt-navigation hdt-position-default hdt-visible-always hdt-style-default hdt-shape-rounded hdt-size-small hdt-hide-mobile-{{ hide_arrows_mb }}">
          <button aria-controls="PhbSlider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--prev hdt-product-hero-banner__arrow" type="button" disabled name="previous" aria-label="Previous slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button aria-controls="PhbSlider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--next hdt-product-hero-banner__arrow" type="button" disabled name="next" aria-label="Next slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- if show_dots -%}
        <div hdt-slider-dots aria-controls="PhbSlider-{{ section.id }}" class="hdt-product-hero-banner__dots hdt-slider__dots hdt-pagination hdt-position-center hdt-style-default hdt-radius-true hdt-hide-mobile-{{ hide_dots_mb }}" style="--space-between: 8px; --margin-top: -34px;"></div>
      {%- endif -%}
    </hdt-slideshow>
  {%- elsif request.design_mode -%}
    <p class="hdt-product-hero-banner__empty">Add “Slide” blocks in the theme editor to build the product hero.</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Product Hero",
  "tag": "section",
  "class": "hdt-section hdt-product-hero-banner-section section-allow-transparent",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Background image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image (desktop)",
          "info": "Composed image with the product + empty space for the copy."
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Background image (mobile)",
          "info": "Optional. Product lower / empty space at top. Falls back to desktop image."
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "select",
          "id": "focal_desktop",
          "label": "Image focus (desktop)",
          "info": "Used when height mode is Fixed.",
          "options": [
            { "value": "left center", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right center", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "focal_mobile",
          "label": "Image focus (mobile)",
          "info": "Used when height mode is Fixed.",
          "options": [
            { "value": "center top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "center bottom", "label": "Bottom" }
          ],
          "default": "center bottom"
        },
        {
          "type": "header",
          "content": "Rating"
        },
        {
          "type": "checkbox",
          "id": "rating_show",
          "label": "Show rating row",
          "default": true
        },
        {
          "type": "text",
          "id": "rating_value",
          "label": "Rating value",
          "default": "4.67"
        },
        {
          "type": "text",
          "id": "rating_max",
          "label": "Rating max",
          "default": "5"
        },
        {
          "type": "text",
          "id": "rating_text",
          "label": "Rating text",
          "default": "Over 12,500 Verified Reviews"
        },
        {
          "type": "color",
          "id": "rating_color",
          "label": "Star color",
          "default": "#E3A519"
        },
        {
          "type": "color",
          "id": "rating_text_color",
          "label": "Rating text color",
          "default": "#8A857C"
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Medi Lift Moisture Serum — Moisturizing Facial Serum"
        },
        {
          "type": "richtext",
          "id": "text_1",
          "label": "Description line 1",
          "default": "<p>Not just a moisturizing serum—it is a smart layer designed to help your device work more effectively on your skin.</p>"
        },
        {
          "type": "richtext",
          "id": "text_2",
          "label": "Description line 2",
          "default": "<p>If you use MEDI LIFT EMS devices, this product is not an optional extra—it is an essential part of the experience.</p>"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#111111"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Description color",
          "default": "#2A2A2A"
        },
        {
          "type": "header",
          "content": "Content position"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Horizontal position (desktop)",
          "options": [
            { "value": "flex-start", "label": "Start" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "End" }
          ],
          "default": "flex-end"
        },
        {
          "type": "select",
          "id": "content_valign",
          "label": "Vertical position (desktop)",
          "options": [
            { "value": "flex-start", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Bottom" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Text alignment (desktop)",
          "options": [
            { "value": "start", "label": "Start" },
            { "value": "center", "label": "Center" },
            { "value": "end", "label": "End" }
          ],
          "default": "start"
        },
        {
          "type": "range",
          "id": "content_max_width",
          "min": 320,
          "max": 820,
          "step": 10,
          "unit": "px",
          "label": "Content max width (desktop)",
          "default": 600
        },
        {
          "type": "select",
          "id": "content_position_mobile",
          "label": "Vertical position (mobile)",
          "options": [
            { "value": "flex-start", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "flex-end", "label": "Bottom" }
          ],
          "default": "flex-start"
        },
        {
          "type": "select",
          "id": "text_align_mobile",
          "label": "Text alignment (mobile)",
          "options": [
            { "value": "start", "label": "Start" },
            { "value": "center", "label": "Center" },
            { "value": "end", "label": "End" }
          ],
          "default": "center"
        },
        {
          "type": "range",
          "id": "content_max_width_mb",
          "min": 240,
          "max": 640,
          "step": 10,
          "unit": "px",
          "label": "Content max width (mobile)",
          "default": 460
        },
        {
          "type": "header",
          "content": "Badges / tabs"
        },
        {
          "type": "color",
          "id": "badge_bg",
          "label": "Badge background",
          "default": "#F7F5EF"
        },
        {
          "type": "color",
          "id": "badge_text_color",
          "label": "Badge text",
          "default": "#5F594E"
        },
        {
          "type": "color",
          "id": "badge_border_color",
          "label": "Badge border",
          "default": "#E7E1D4"
        },
        {
          "type": "text",
          "id": "badge_1_text",
          "label": "Badge 1 text",
          "default": "Supportive Glide"
        },
        {
          "type": "liquid",
          "id": "badge_1_svg",
          "label": "Badge 1 icon (SVG)"
        },
        {
          "type": "image_picker",
          "id": "badge_1_image",
          "label": "Badge 1 icon (image)"
        },
        {
          "type": "url",
          "id": "badge_1_link",
          "label": "Badge 1 link"
        },
        {
          "type": "text",
          "id": "badge_2_text",
          "label": "Badge 2 text",
          "default": "Soft Skin"
        },
        {
          "type": "liquid",
          "id": "badge_2_svg",
          "label": "Badge 2 icon (SVG)"
        },
        {
          "type": "image_picker",
          "id": "badge_2_image",
          "label": "Badge 2 icon (image)"
        },
        {
          "type": "url",
          "id": "badge_2_link",
          "label": "Badge 2 link"
        },
        {
          "type": "text",
          "id": "badge_3_text",
          "label": "Badge 3 text",
          "default": "Deep Hydration"
        },
        {
          "type": "liquid",
          "id": "badge_3_svg",
          "label": "Badge 3 icon (SVG)"
        },
        {
          "type": "image_picker",
          "id": "badge_3_image",
          "label": "Badge 3 icon (image)"
        },
        {
          "type": "url",
          "id": "badge_3_link",
          "label": "Badge 3 link"
        },
        {
          "type": "text",
          "id": "badge_4_text",
          "label": "Badge 4 text",
          "default": "Japanese Technology"
        },
        {
          "type": "liquid",
          "id": "badge_4_svg",
          "label": "Badge 4 icon (SVG)"
        },
        {
          "type": "image_picker",
          "id": "badge_4_image",
          "label": "Badge 4 icon (image)"
        },
        {
          "type": "url",
          "id": "badge_4_link",
          "label": "Badge 4 link"
        },
        {
          "type": "text",
          "id": "badge_5_text",
          "label": "Badge 5 text"
        },
        {
          "type": "liquid",
          "id": "badge_5_svg",
          "label": "Badge 5 icon (SVG)"
        },
        {
          "type": "image_picker",
          "id": "badge_5_image",
          "label": "Badge 5 icon (image)"
        },
        {
          "type": "url",
          "id": "badge_5_link",
          "label": "Badge 5 link"
        },
        {
          "type": "text",
          "id": "badge_6_text",
          "label": "Badge 6 text"
        },
        {
          "type": "liquid",
          "id": "badge_6_svg",
          "label": "Badge 6 icon (SVG)"
        },
        {
          "type": "image_picker",
          "id": "badge_6_image",
          "label": "Badge 6 icon (image)"
        },
        {
          "type": "url",
          "id": "badge_6_link",
          "label": "Badge 6 link"
        },
        {
          "type": "header",
          "content": "Overlay (this slide)"
        },
        {
          "type": "checkbox",
          "id": "use_overlay_override",
          "label": "Override section overlay",
          "default": false
        },
