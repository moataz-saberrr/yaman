<!-- sections/yaman-how-to-use-n.liquid — YAMAN product-page "How to Use" steps
  Desktop: static 4-card grid. Mobile: full-bleed CSS scroll-snap carousel (no JS,
  no library) showing one full card + a peek of the next. Section-local card blocks.
  CSS: assets/custom-productan.css (scoped under .hdt-yaman-howuse-section) -->
{{ 'custom-productan.css' | asset_url | stylesheet_tag: media: 'all' }}
{%- liquid
  assign count = section.blocks.size
  assign cols = section.settings.columns | default: 4
-%}
<div
  class="hdt-yaman-howuse{% if section.settings.show_glow %} has-glow{% endif %}{% if section.settings.enable_carousel_mobile %} has-carousel{% endif %}{% if section.settings.full_bleed_mobile %} is-fullbleed{% endif %}"
  id="yaman-howuse-{{ section.id }}"
  style="
    --hu-bg: {{ section.settings.background_color }};
    --hu-glow: {{ section.settings.glow_color }};
    --hu-maxw: {{ section.settings.container_max_width }}px;
    --hu-head-maxw: {{ section.settings.header_max_width }}px;
    --hu-cols: {{ cols }};
    --hu-gap: {{ section.settings.gap }}px;
    --hu-gap-mb: {{ section.settings.gap_mb }}px;
    --hu-card-bg: {{ section.settings.card_bg }};
    --hu-radius: {{ section.settings.card_radius }}px;
    --hu-img-ar: {{ section.settings.image_ratio }};
    --hu-accent: {{ section.settings.accent_color }};
    --hu-title: {{ section.settings.title_color }};
    --hu-card-mb: {{ section.settings.mobile_card_width }}%;
    --hu-pt: {{ section.settings.padding_top }}px;
    --hu-pb: {{ section.settings.padding_bottom }}px;
    --hu-pt-mb: {{ section.settings.padding_top_mb }}px;
    --hu-pb-mb: {{ section.settings.padding_bottom_mb }}px;
  "
>
  <div class="hdt-yaman-howuse__container">

    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="hdt-yaman-howuse__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="hdt-yaman-howuse__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="hdt-yaman-howuse__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if count > 0 -%}
      <div class="hdt-yaman-howuse__viewport">
        <div class="hdt-yaman-howuse__track">
          {%- for block in section.blocks -%}
            {%- liquid
              assign img = block.settings.image
              assign img_mb = block.settings.image_mobile
              assign alt = block.settings.image_alt | default: block.settings.title
              assign link = block.settings.link
              assign tag = 'div'
              if link != blank
                assign tag = 'a'
              endif
            -%}
            <{{ tag }}
              class="hdt-yaman-howuse__card"
              {% if link != blank %}href="{{ link }}"{% endif %}
              {{ block.shopify_attributes }}
            >
              <div class="hdt-yaman-howuse__image-wrap">
                {%- if img != blank -%}
                  {%- if img_mb != blank -%}
                    <picture>
                      <source media="(max-width: 767px)" srcset="{{ img_mb | image_url: width: 700 }}, {{ img_mb | image_url: width: 1000 }} 1.5x">
                      {{ img | image_url: width: 600 | image_tag: class: 'hdt-yaman-howuse__image', alt: alt, loading: 'lazy', widths: '223,340,460,600', sizes: '(max-width: 767px) 78vw, 260px' }}
                    </picture>
                  {%- else -%}
                    {{ img | image_url: width: 600 | image_tag: class: 'hdt-yaman-howuse__image', alt: alt, loading: 'lazy', widths: '223,340,460,600', sizes: '(max-width: 767px) 78vw, 260px' }}
                  {%- endif -%}
                {%- else -%}
                  <div class="hdt-yaman-howuse__image hdt-yaman-howuse__placeholder" aria-hidden="true">
                    {{ 'image' | placeholder_svg_tag: 'hdt-yaman-howuse__placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>

              <div class="hdt-yaman-howuse__body">
                {%- if block.settings.number != blank -%}
                  <span class="hdt-yaman-howuse__number">{{ block.settings.number }}</span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="hdt-yaman-howuse__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="hdt-yaman-howuse__description">{{ block.settings.description | escape }}</p>
                {%- endif -%}
              </div>
            </{{ tag }}>
          {%- endfor -%}
        </div>
      </div>
    {%- elsif request.design_mode -%}
      <p class="hdt-yaman-howuse__empty">Add “Step” blocks in the theme editor to build the steps.</p>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "YAMAN How Use",
  "tag": "section",
  "class": "hdt-section hdt-yaman-howuse-section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image (optional)"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "STEP TITLE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to Use"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Four simple steps designed to fit seamlessly into your routine."
    },
    {
      "type": "range",
      "id": "header_max_width",
      "min": 400,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Header max width",
      "default": 760
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Show gold glow",
      "default": true
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#d4b87a"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 800,
      "max": 1400,
      "step": 10,
      "unit": "px",
      "label": "Container max width",
      "default": 1040
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "min": 8,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Card gap (desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "gap_mb",
      "min": 6,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card gap (mobile)",
      "default": 16
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#f8f7f0"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Card corner radius",
      "default": 16
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "223 / 200", "label": "Figma (1.1 : 1)" },
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 5", "label": "Portrait" },
        { "value": "4 / 3", "label": "Landscape" }
      ],
      "default": "223 / 200"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Number / accent color",
      "default": "#c9a844"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1d2847"
    },
    {
      "type": "header",
      "content": "Mobile carousel"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel_mobile",
      "label": "Enable mobile carousel",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "full_bleed_mobile",
      "label": "Full-bleed carousel (mobile)",
      "default": true
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "min": 60,
      "max": 90,
      "step": 1,
      "unit": "%",
      "label": "Card width (mobile)",
      "info": "Lower = more of the next card peeks in.",
      "default": 78
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "YAMAN How Use",
      "category": "t:sections_categories.05_section.name",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "APPLY GEL OR SERUM",
            "description": "Prepare the lower face with a suitable gel or compatible serum before use."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "SECURE THE MASK PROPERLY",
            "description": "Fit the mask comfortably and securely over the cheeks and jaw area."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "ADJUST EACH SIDE",
            "description": "Set the intensity for the left and right sides independently to suit your needs."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "04",
            "title": "WEAR FOR 10 MINUTES",
            "description": "Enjoy a hands-free, 10-minute daily routine."
          }
        }
      ]
    }
  ]
}
{% endschema %}
