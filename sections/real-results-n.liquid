<!-- section/real-results-n.liquid — YAMAN "Real Results. Clinically Proven." before/after carousel -->
{{ 'slideshow.css' | asset_url | stylesheet_tag: media: 'all' }}
<div
  class="hdt-yaman-results-section{% unless section.index == 1 %} hdt-reveal-section{% endunless %}"
  {%- unless section.index == 1 %} hdt-reveal="fade-in"{%- endunless %}
  style="--rr-bg: {{ section.settings.background_color }}; --rr-maxw: {{ section.settings.container_max_width }}px; --rr-radius: {{ section.settings.card_radius }}px; --rr-cols-dk: {{ section.settings.cards_dk }}; --rr-cols-tb: {{ section.settings.cards_tb }}; --rr-w-mb: {{ section.settings.mobile_card_width }}%; --rr-gap: {{ section.settings.gap }}px; --rr-gap-tb: {{ section.settings.gap_tb }}px; --rr-gap-mb: {{ section.settings.gap_mb }}px; --rr-pt: {{ section.settings.padding_top }}px; --rr-pb: {{ section.settings.padding_bottom }}px; --rr-pt-mb: {{ section.settings.padding_top_mb }}px; --rr-pb-mb: {{ section.settings.padding_bottom_mb }}px;"
>
  <div class="hdt-yaman-results">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="hdt-yaman-results__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="hdt-yaman-results__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hdt-yaman-results__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <hdt-slideshow
      id="Slider-{{ section.id }}"
      class="hdt-yaman-results__slider hdt-slider hdt-relative hdt-slideshow hdt-slides-2"
      config='{"loop": {{ section.settings.loop }}, "navUI": {{ section.settings.navUI }}, "dotUI": {{ section.settings.dotUI }}, "autoPlay": {{ section.settings.autoplay | times: 1000 }}, "pauseOnHover": {{ section.settings.pauseOnHover }}, "autoHeight": false, "slidesToScroll": 1 }'
    >
      <div class="hdt-slider__viewport hdt-relative">
        <div class="hdt-slider__container">
          {% content_for "blocks" %}
        </div>
      </div>
      {%- if section.settings.navUI -%}
        <div class="hdt-navigation hdt-position-default hdt-visible-hover hdt-style-default hdt-shape-rounded hdt-size-small hdt-hide-mobile-false">
          <button aria-controls="Slider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--prev" type="button" disabled name="previous" aria-label="previous">
            <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M5.5 11L0 5.5L5.5 0L6.47625 0.97625L1.9525 5.5L6.47625 10.0238L5.5 11Z" fill="currentColor"/></svg>
          </button>
          <button aria-controls="Slider-{{ section.id }}" class="hdt-slider__button hdt-slider__button--next" type="button" disabled name="next" aria-label="next">
            <svg xmlns="http://www.w3.org/2000/svg" width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M1.5 11L7 5.5L1.5 0L0.52375 0.97625L5.0475 5.5L0.52375 10.0238L1.5 11Z" fill="currentColor"/></svg>
          </button>
        </div>
      {%- endif -%}
      {%- if section.settings.dotUI -%}
        <div hdt-slider-dots aria-controls="Slider-{{ section.id }}" class="hdt-slider__dots hdt-pagination hdt-position-center hdt-style-default hdt-radius-true hdt-hide-mobile-false" style="--space-between: 10px; --margin-top: 18px;" hdt-reveal="slide-in" timeline></div>
      {%- endif -%}
    </hdt-slideshow>
  </div>
</div>
<script src="{{ 'real-results-n.js' | asset_url }}" defer></script>
{% schema %}
{
  "name": "YAMAN Results",
  "tag": "section",
  "class": "hdt-section hdt-yaman-results-wrap section-allow-transparent",
  "blocks": [{ "type": "_real-result-card-n" }],
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results. Clinically Proven."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "GCC women. Real devices. Zero filters."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f7f0"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 1000,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "label": "Container max width",
      "default": 1310
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Image corner radius",
      "default": 20
    },
    {
      "type": "header",
      "content": "Cards per view"
    },
    {
      "type": "range",
      "id": "cards_dk",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Cards — desktop (≥1150px)",
      "default": 4
    },
    {
      "type": "range",
      "id": "cards_tb",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Cards — tablet (768–1149px)",
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Card width — mobile",
      "info": "Below 50% of the row width shows 2 cards + a peek of the next. Lower = more peek.",
      "default": 45
    },
    {
      "type": "header",
      "content": "Gaps"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap — desktop",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_tb",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Gap — tablet",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mb",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Gap — mobile",
      "default": 12
    },
    {
      "type": "header",
      "content": "Before / after"
    },
    {
      "type": "range",
      "id": "default_position",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Default divider position",
      "default": 50
    },
    {
      "type": "header",
      "content": "Carousel behavior"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay",
      "min": 0,
      "max": 7,
      "step": 0.5,
      "unit": "s",
      "label": "Autoplay",
      "info": "0 = off.",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "pauseOnHover",
      "label": "Pause on hover",
      "default": true,
      "visible_if": "{{ section.settings.autoplay > 0 }}"
    },
    {
      "type": "checkbox",
      "id": "navUI",
      "label": "Show arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "dotUI",
      "label": "Show dots",
      "default": false
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 10,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "YAMAN Results",
      "category": "t:sections_categories.05_section.name",
      "blocks": [
        {
          "type": "_real-result-card-n",
          "settings": {
            "title": "93% Firmer Skin",
            "meta": "Reem, 42 · Dubai · 8 weeks",
            "product_text": "Medi Lift Plus",
            "button_label": "Shop Medi Lift Plus"
          }
        },
        {
          "type": "_real-result-card-n",
          "settings": {
            "title": "89% Reduced Sagging",
            "meta": "Noura, 38 · Riyadh · 10 weeks",
            "product_text": "LIFTOLOGY SP",
            "button_label": "Shop LIFTOLOGY SP"
          }
        },
        {
          "type": "_real-result-card-n",
          "settings": {
            "title": "89% Reduced Sagging",
            "meta": "Sara, 45 · Abu Dhabi · 12 weeks",
            "product_text": "Photo Plus Prestige SP",
            "button_label": "Shop Photo Plus SP"
          }
        },
        {
          "type": "_real-result-card-n",
          "settings": {
            "title": "89% Reduced Sagging",
            "meta": "Hessa, 36 · Kuwait · 6 weeks",
            "product_text": "Hydra Bright Skin Set",
            "button_label": "Shop Hydra Bright"
          }
        }
      ]
    }
  ]
}
{% endschema %}
