<!-- custom-section-n.liquid — YAMAN newsletter text banner (duplicated from custom-section.liquid) -->
{%- liquid
  assign al_class = 'is-al-' | append: section.settings.content_align
  assign almb_class = 'is-almb-' | append: section.settings.content_align_mb
  assign form_id = 'hdt-yaman-nl-' | append: section.id

  assign email_ph = section.settings.email_placeholder
  if email_ph == blank
    assign email_ph = 'sections.newsletter_form.email_placeholder' | t
  endif

  assign btn_label = section.settings.button_label
  if btn_label == blank
    assign btn_label = 'newsletter.button_label' | t
  endif
-%}
<div
  id="{{ section.id }}"
  class="hdt-yaman-newsletter-banner hdt-custom-section-n {{ al_class }} {{ almb_class }}"
  hdt-reveal="fade-in"
  style="--nl-bg: {{ section.settings.background_color }}; --nl-maxw: {{ section.settings.container_max_width }}px; --nl-pt: {{ section.settings.padding_top }}px; --nl-pb: {{ section.settings.padding_bottom }}px; --nl-pt-mb: {{ section.settings.padding_top_mb }}px; --nl-pb-mb: {{ section.settings.padding_bottom_mb }}px;"
>
  <div class="hdt-yaman-newsletter">
    <div class="hdt-yaman-newsletter__container">

      <div class="hdt-yaman-newsletter__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="hdt-yaman-newsletter__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="hdt-yaman-newsletter__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="hdt-yaman-newsletter__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      <div class="hdt-yaman-newsletter__form-wrap">
        {%- form 'customer', id: form_id, class: 'hdt-yaman-newsletter__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="hdt-yaman-newsletter__field">
            <input
              type="email"
              name="contact[email]"
              class="hdt-yaman-newsletter__input"
              pattern="^[^@\s]+@[^@\s]+\.[^@\s]+$"
              placeholder="{{ email_ph }}"
              value="{% if customer %}{{ customer.email }}{% endif %}"
              aria-label="{{ email_ph }}"
              required="required"
            >
            <button type="submit" class="hdt-yaman-newsletter__button">
              {{ btn_label }}
            </button>
          </div>
          <div data-hdt-response-form class="hdt-yaman-newsletter__response">
            {%- if form.posted_successfully? -%}
              <p class="hdt-yaman-newsletter__success">{{ 'sections.newsletter_form.confirmation' | t }}</p>
            {%- elsif form.errors -%}
              <p class="hdt-yaman-newsletter__error">{{ form.errors | default_errors }}</p>
            {%- endif -%}
          </div>
        {%- endform -%}

        {%- if section.settings.whatsapp_url != blank -%}
          <a class="hdt-yaman-newsletter__whatsapp" href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener noreferrer">
            {{ section.settings.whatsapp_text }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>
{% schema %}
{
  "name": "Custom section-n",
  "tag": "section",
  "class": "hdt-section hdt-yaman-newsletter-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "JOIN THE COMMUNITY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the YAMAN Edit"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off · Exclusive tutorials · Member-only access"
    },
    {
      "type": "header",
      "content": "Newsletter form"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "WhatsApp opt-in"
    },
    {
      "type": "text",
      "id": "whatsapp_text",
      "label": "WhatsApp text",
      "default": "OR OPT IN VIA WHATSAPP"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL",
      "info": "Leave blank to hide the WhatsApp opt-in link."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f7f0"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Container max width",
      "default": 1000
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "start"
    },
    {
      "type": "select",
      "id": "content_align_mb",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 65
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 65
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 45
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 45
    }
  ],
  "presets": [
    {
      "name": "Custom section-n",
      "category": "t:sections_categories.05_section.name"
    }
  ]
}
{% endschema %}
