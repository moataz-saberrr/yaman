<!-- accordion.liquid -->
{% style %}
  {% render 'spacing-vars', box: section %}
{% endstyle %}
{%- liquid
  #Section layout
  assign sizes  = '(min-width: 1150px) ' | append: settings.page_width | append: 'px,(min-width: 750px) calc(100vw - 60px), calc(100vw - 30px)'

  case section.settings.section_layout 
    when 'container'
      assign parent = 'hdt-container'
      assign child  = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
    when 'wrapper_container'
      assign parent = 'hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = 'hdt-container'
    when 'full_width'
      assign parent = 'hdt-container-full hdt-section-spacing hdt-s-gradient hdt-relative' | append: ' hdt-section-spacing-' | append: section.id
      assign child  = ''
      assign sizes  = '100vw'
  endcase

  # YAMAN FAQ (Accordion Design 3): scope class so its CSS can't touch design 1/2
  assign faq_class = ''
  if section.settings.accordion_des == '3'
    assign faq_class = ' hdt-yaman-faq-section'
  endif
-%}

<div id="{{ section.id }}" class="{{ parent }}{{ faq_class }} {% if section.settings.hdt_background_parallax %} hdt-animate--parallax-bg {% endif %} hdt-s-gradient hdt-section-spacing hdt-section-spacing-{{ section.id }}" {%- if section.settings.colors_by_section %} color-scheme="{{ section.settings.color_scheme }}" style="--background-opacity: {{ section.settings.background_opacity }};"{%- endif %}>
  <div class="{{ child }}">
    {%- if section.settings.section_background != blank -%}
      {% liquid
        assign image = section.settings.section_background
      %}
      {{ image | image_url: width: image.width | image_tag: width: image.width, height: image.height, sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1100,1200,1300,1400,1500,1600,1700,1800,1900,2000', loading: 'lazy', class: 'hdt-section-background hdt-absolute hdt-top-0 hdt-left-0 hdt-w-full hdt-h-full hdt-pe-none hdt-object-cover hdt-object-center' }}
    {%- endif -%}
    {% content_for "block", type: "section-heading", id: "accordion-heading" %}
    <div class="hdt-flex hdt-flex-col hdt-justify-between hdt-row-accordion hdt-accordion-style{{ section.settings.accordion_des }}">
      {% content_for "blocks" %}
    </div>
  </div>
</div>
{%- style -%}
  #{{ section.id }} .hdt-row-accordion {
    gap: 10px;
  }
  {%- if section.settings.accordion_des == '3' -%}
    #{{ section.id }} {
      --faq-max-w: {{ section.settings.faq_max_width | default: 776 }}px;
    }
  {%- endif -%}
{%- endstyle -%}
{% schema %}
{
  "name": "Accordion 2",
  "tag": "section",
  "class": "hdt-section hdt-accordion",
  "disabled_on": {
    "groups": [
      "*"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.general_options.label"
    },
    {
      "type": "select",
      "id": "accordion_des",
      "label": "t:sections.accordion.settings.accordion_des",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "faq_max_width",
      "min": 480,
      "max": 1200,
      "step": 8,
      "unit": "px",
      "label": "FAQ width (Design 3)",
      "default": 776,
      "info": "Desktop max width for the YAMAN FAQ column. Mobile is always full width.",
      "visible_if": "{{ section.settings.accordion_des == '3' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.section_layout.label"
    },
    {
      "type": "select",
      "id": "section_layout",
      "label": "t:sections.all.section_layout.width.label",
      "options": [
        {
          "value": "container",
          "label": "t:sections.all.section_layout.width.container"
        },
        {
          "value": "wrapper_container",
          "label": "t:sections.all.section_layout.width.wrapper_container"
        },
        {
          "value": "full_width",
          "label": "t:sections.all.section_layout.width.full_width"
        }
      ],
      "default": "container"
    },
    {
      "type": "image_picker",
      "id": "section_background",
      "label": "t:sections.all.background.image"
    },
    {
      "type": "checkbox",
      "id": "hdt_background_parallax",
      "label": "Using parallax for background",
      "visible_if": "{{ section.settings.section_background != blank }}",
      "default": false
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "checkbox",
      "id": "colors_by_section",
      "label": "t:sections.all.colors.display_colors_by_section"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "visible_if": "{{ section.settings.colors_by_section }}"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.all.background.opacity",
      "default": 0,
      "visible_if": "{{ section.settings.colors_by_section }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_spacing"
    },
    {
      "type": "text",
      "id": "mg",
      "label": "Margin",
      "info": "Margin top, margin right, margin bottom, margin left. If you not use to blank",
      "default": ",,50px,",
      "placeholder": ",,50px,"
    },
    {
      "type": "text",
      "id": "mg_mb",
      "label": "Margin (Mobile)",
      "default": ",,30px,",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.mg != blank }}"
    },
    {
      "type": "text",
      "id": "pd",
      "label": "Padding",
      "info": "Padding top, padding right, padding bottom, padding left. If you not use to blank",
      "placeholder": "50px,,50px,"
    },
    {
      "type": "text",
      "id": "pd_mb",
      "label": "Padding (Mobile)",
      "placeholder": ",,50px,",
      "visible_if": "{{ section.settings.pd != blank }}"
    }
  ],
  "blocks": [
    {
      "type": "_accordion-item"
    }
  ],
  "presets": [
    {
      "name": "Accordion 2",
      "category": "t:sections_categories.05_section.name",
      "blocks": [
        {
          "type": "_accordion-item",
          "settings": {
            "open": true,
            "title": "Do I need to open an account in order to shop with you?",
            "content": "<p>No, you don't need to. You can make purchases and check out as a guest everytime. However, by setting up an account with us, it will allow you to order without having to enter your details every time you shop with us. You can sign up right now, or you can first start shopping and create your account before you check out at the shopping cart page.</p>"
          }
        },
        {
          "type": "_accordion-item",
          "settings": {
            "title": "How do I /create an account?",
            "content": "<p>Please click on \"Login/Register\" followed by 'Create An Account' and fill in your personal particulars.</p>"
          }
        },
        {
          "type": "_accordion-item",
          "settings": {
            "title": "How do I order?",
            "content": "<p>Shop for the items you want and add it to your shopping cart. When you have finished, you can proceed to your shopping cart and check out. Check and ensure that all information is correct before confirming your purchases and payment.</p>"
          }
        },
        {
          "type": "_accordion-item",
          "settings": {
            "title": "How do I pay for my orders?",
            "content": "<p>Shop for the items you want and add it to your shopping cart. When you have finished, you can proceed to your shopping cart and check out. Check and ensure that all information is correct before confirming your purchases and payment.</p>"
          }
        }
      ]
    },
    {
      "name": "YAMAN FAQ",
      "category": "t:sections_categories.05_section.name",
      "settings": {
        "accordion_des": "3",
        "faq_max_width": 776,
        "section_layout": "container"
      },
      "blocks": [
        {
          "type": "section-heading",
          "static": true,
          "id": "accordion-heading",
          "settings": {
            "design_heading": "1",
            "horizontal": false,
            "alignment": "left",
            "heading_gap": 0,
            "margin_bottom": 24
          },
          "blocks": [
            {
              "type": "_heading_section",
              "settings": {
                "heading": "Clarity before commitment.",
                "heading_size": "h_custom",
                "font_size_heading_lg": 48,
                "font_size_heading": 32,
                "text_color": "hdt-s-text"
              }
            }
          ]
        },
        {
          "type": "_accordion-item",
          "settings": {
            "title": "How does the Medi Lift Plus work?",
